				$errLabel = $('<div class="invalid-tooltip"></div>');
				if(data.id == 0) {
					$errLabel.html('Debe seleccionar el producto a traspasar');
					$('#producto-producto').after($errLabel).focus();
					$errLabel.show();
				} else if(data.cantidad.length==0 || parseInt(data.cantidad)==0) {
					$errLabel.html('Debe ingresar la cantidad a traspasar');
					$('#producto-cantidad').after($errLabel).focus();
					$errLabel.show();
				} else {
					if(!prodExists(data.id)) {
						addProductoRow(data);
						clearDataProducto();
						$('#frm-producto').modal('hide');
					}
				}
			}

			$("#producto-existencias, #producto-cantidad").inputmask({ alias: "numeric"});
