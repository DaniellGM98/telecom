					$errLabel.html('Stock insuficiente');
					$('#producto-cantidad').after($errLabel).val(0).focus();
					$errLabel.show();
				}
			});

			$("#producto-cantidad").keyup(function(event) { if(event.keyCode == 13) addProducto(); });
