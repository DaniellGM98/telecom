			function prodExists(prod) {
				if($('#tbl-productos [data-id="'+prod+'"]').length > 0) {
					$errLabel = $('<div class="invalid-tooltip">Ya existe el producto</div>');
					$('#producto-producto').after($errLabel).select().focus();
					$('#producto-producto_id').val(0);
					$errLabel.show();

					return true;
				}
				return false;
			}

