				function saveTraspaso() {
					$('.invalid-tooltip').remove();
					data = { folio: $.trim($('#traspaso-folio').val()), origen: $('#traspaso-origen').val(), destino: $('#traspaso-destino').val(), };
					if($('#sku').is(':visible')) { 
						data.detalles = [{
							producto_id: $('#traspaso-producto_id').val(), 
							arrSku: $('#traspaso-sku').val(), 
							cantidad: $('#traspaso-sku').val().length
						}];
					} else { 
						data.detalles = [{
							producto_id: $('#traspaso-producto_id').val(), 
							cantidad: $('#traspaso-cantidad').val()
						}]; 
					}

					$errLabel = $('<div class="invalid-tooltip"></div>');
					if(data.origen == 0) {
						$errLabel.html('Debe seleccionar el origen');
						$('#traspaso-origen').after($errLabel).focus();
						$errLabel.show();
					} else if(data.destino == 0) {
						$errLabel.html('Debe seleccionar el destino');
						$('#traspaso-destino').after($errLabel).focus();
						$errLabel.show();
					} else if(data.folio == '') {
						$errLabel.html('Debe ingresar el folio');
						$('#traspaso-folio').after($errLabel).focus();
						$errLabel.show();
					} else if(!$('#sku').is(':visible') && (parseInt(data.detalles[0].cantidad)==0 || data.detalles[0].cantidad.length==0)) {
						$errLabel.html('Debe ingresar la cantidad');
						$('#traspaso-cantidad').after($errLabel);
						$errLabel.show();
					} else if($('#sku').is(':visible') && $('#traspaso-sku').val().length==0) {
						$errLabel.html('Debe seleccionar los '+$('#traspaso-categoria_sku').val()+' de la lista');
						$('#traspaso-sku').after($errLabel);
						$errLabel.show();
					} else {
						blockPage();
						url = '2/' + data.origen + '/' + data.detalles[0].producto_id;
						if($('#sku').is(':visible')) { url += '/' + data.detalles[0].arrSku; }
						$.get('<?= URL_API ?>traspaso/getAll/'+url, function(traspasos) {
							if(traspasos.result.length==0 || (!$('#sku').is(':visible') && parseInt(traspasos.suma)+parseInt(data.detalles[0].cantidad)<=parseInt(traspasos.stock))) {
								$.post('<?= URL_API ?>traspaso/solicitarTraspaso/', data, function(traspaso) {
									if(traspaso.response) {
										getProductos();
										$('#frm-traspaso').modal('hide');
										swal({ type:"success", title:"¡Listo!", text:"Se guardaron los datos correctamente.", timer:4000 });
									} else { swal({ type:"warning", title:"Oops!", text:traspaso.message, timer:4000 }); }

									$.unblockUI();
								}, 'json');
							} else {
								swal({ type:"warning", title:"Oops!", text:'El producto seleccionado cuenta con traspasos pendientes<br>Confirma o cancela dichas solicitudes e intentalo una vez más', html: true, timer:4000 }); 
								$.unblockUI();
							}
						}, 'json');
					}
				}
			<?php endif; ?>


			function clearData() {
				$('.invalid-tooltip').remove();
				$('#frm-producto input').val('');
