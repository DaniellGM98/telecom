			function getTrElement(tblName, tr) {
				container = $('<div></div>');
				trInfo = $('#'+tblName).DataTable().row(tr).data();
				$.each(trInfo, function(index, trInfoRow) {
					container.append(trInfoRow);
				});
				
				return container;
			}

			function reloadTable() {
				arrColumnas=$('#columnas-tbl-producto').val(); arrCategorias=$('#categorias-tbl-producto').val(); arrSubcategorias=$('#subcategorias-tbl-producto').val(); arrMarcas=$('#marcas-tbl-producto').val(); arrSucursal=$('#sucursal-tbl-producto').val(); arrListaPrecio=$('#lista_precios-tbl-producto').val(); busqueda=$.trim($('#bus').val()).length>0? $.trim($('#bus').val()): '_';
				cleanTable('tbl-producto'); createTable('tbl-producto', arrColumnas, arrCategorias, arrSubcategorias, arrMarcas, arrSucursal, arrListaPrecio, busqueda);
			}

			function cleanTable(tbl) {
				if($.fn.dataTable.isDataTable('#'+tbl)) {
					table = $('#'+tbl).DataTable();
					table.destroy();
				}
				$("#nodata").remove();
			}

			//$('#toolbar-tbl-producto').on('changed.bs.select', '.selectpicker:not(#columnas-tbl-producto)', function() { blockPage();
			$('body').on('changed.bs.select', '.selectpicker:not(#columnas-tbl-producto)', function() { blockPage();
				if($(this).val().length > 0){
					if($(this).attr('id')=='filter-sucursal-tbl-existencias'){
						sucId = parseInt($(this).val());
						if(sucId == 0){
							$('#tbl-existencias tbody tr').css('display', '');
						}else{
							$.each($('#tbl-existencias tbody tr'), function (indexInArray, elem) { 
								if($(elem).find('.sucursal').data('id') != sucId) $(elem).css('display', 'none');
								else $(elem).css('display', '');
							});
						}
					}else{
						arrColumnas = fColumnas.val();
						arrCategorias = fCategorias.val();
						arrSubcategorias = fSubcategorias.val();
						arrMarcas = fMarcas.val();
						arrSucursal = fSucursal.val();
						arrListaPrecio = $(this).attr('id')=='sucursal-tbl-producto'? null: fListaPrecio.val();
						busqueda = $.trim($('#bus').val()).length>0? $.trim($('#bus').val()): '_';
						cleanTable('tbl-producto'); createTable('tbl-producto', arrColumnas, arrCategorias, arrSubcategorias, arrMarcas, arrSucursal, arrListaPrecio, busqueda);
					}
				}
				$.unblockUI();
			});

