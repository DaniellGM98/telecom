				e.preventDefault();
				title = $(this).attr('title').replace('Ver ', '');
				skuname = title.split(' ')[0];
				infoProducto = getTrElement('tbl-producto', $(this).parents('tr')).find('.producto');
				prodname = infoProducto.text();
				prodid = infoProducto.data('id');
				$('#frm-existencias .modal-title').html(title+' <strong>'+prodname+'</strong>');
				$('#tbl-existencias thead tr th.skuname').html(skuname);

				container = $('#tbl-existencias tbody'); cleanTable('tbl-existencias'); container.empty();
				suc = $('#sucursal-tbl-producto').val();
				$.get($apiUrl.replace('producto', 'prod_entrada_detalle')+'getListaSkuDisp/'+prodid+'/<?= $_SESSION['sucursal'] ?>', function(existencias) {
					arrSucE = [];
					$.each(existencias.result, function(index, item) {
						tr = $('<tr data-sku="'+item.sku+'"></tr>').appendTo(container);
						<?php if(intval($user->usuario_tipo_id) == 1): ?> tr.append('<td><small class="sucursal" data-id="'+item.sucursal_id+'">'+item.sucursal+'</small></td>'); <?php endif; ?>
						tr.append('<td><small class="skuname">'+item.sku+'</small></td>');
						// tr.append('<td><small class="fechaalta">'+moment(item.fecha).format('DD/MM/YYYY hh:mm:ss')+'</small></td>');
						tr.append('<td><small class="fechaentrada">'+item.fechaEntrada+'</small></td>');
						tr.append('<td><small class="fechaalta">'+item.fecha+'</small></td>');
						if(arrSucE.filter(function(e) { return e.id === item.sucursal_id; }).length == 0){ arrSucE.push({id: item.sucursal_id, nombre: item.sucursal})};
					});
					createTable('tbl-existencias');
				});

