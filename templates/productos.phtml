					$('#traspaso-destino option').removeClass('hide');
					if(value == 0) {
						$('.traspaso-folio, #destino, #cantidad, #sku').addClass('hide');
						$('#traspaso-folio').val('');
						
						$('#traspaso-destino option:not([value="0"])').addClass('hide');
