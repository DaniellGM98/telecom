				$(this).find('input').val('');
				$(this).find('.comprobante').addClass('hide');
				$('#pago-cantidad').val(undefined);
				$('#pago-tipo_pago_id option').first().prop('selected', true).trigger('click');
				$('#btn-comprobante').addClass('hide');
				$('#pago-comprobante').removeAttr('src');
