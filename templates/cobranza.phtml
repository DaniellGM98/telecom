			$('#btn-save-payment').click(function() {
				text = $(this).text();
				comentario = $('#payment-comentario').val();
				if(comentario == '' || comentario == null || comentario == undefined) {
					swal({
						type: "warning",
						title: "Datos insuficientes",
						text: "Debe especificar el motivo de la acción",
						timer: 4000
					});
				} else {
					data = {comentario: comentario, status: (text=='Invalidar'? 3: 1)};
					id = $('#payment-id').val();
					$.ajax({
						url: $apiUrl.replace('cobranza', 'venta_pago')+'edit/'+id,
						type: 'PUT',
						async: false,
						dataType: 'json',
						data: data,
						success: function(resp) {
							$('#frm-payment').modal('hide');
							getItems(0, $('#cont').val());

							swal({
								type: "success",
								title: "¡Listo!",
								text: "Se "+(data.status==3? 'invalidó': 'validó')+" el pago",
								timer: 4000
							});
						}
					});
				}
			});

			$('#frm-payment').on('shown.bs.modal', function() {
