				$('#payment-comentario').val(undefined);
				$('#frm-item').modal('show');
			});

			<?php if(in_array(MOD_ACTION_FACT, $permisos)) : ?>
			$('#item-cliente_id').change(function() {
				$('#chkFact').prop('checked', false);
				$('.invalid-tooltip').remove();
			});

			$('#chkFact').change(function(event) {
				if($(this).is(':checked')){
					$('.invalid-tooltip').remove();
					blockPage();
					$.get($apiUrl.replace('venta','cliente')+'get/'+$('#item-cliente_id').val(), function(data) {
						rfcReg = new RegExp('^[A-Z&Ñ]{3,4}[0-9]{2}(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])[A-Z0-9]{2}[0-9A]$');
						rfc = data.result.rfc;
						//$errLabel = $('<div class="invalid-tooltip"></div>');
						if(!rfcReg.test(rfc)){
							/*$errLabel.html('El cliente no cuenta con un RFC válido');
							$('#chkFact').after($errLabel);
							$errLabel.show();
							setTimeout(function(){ $errLabel.remove() }, 3000);*/
							$('#chkFact').prop('checked', false);
							swal({
								type: "error",
								title: "Oops!",
								text: 'El cliente no tiene un RFC válido.<br><small>Debe modificar los datos en el catálogo de <a href="<?= URL_ROOT ?>/clientes" title="Clientes" target="_blank">clientes</a></small>',
								html: true,
								timer: 4000
							});
						}
						if(data.timbres == 0){
							$('#chkFact').prop('checked', false);
							$('#chkFact').prop('disabled', true);
							$('#chkFact').parents('.col-sm-4').find('small.text-muted').html('No cuenta con folios para facturar');
						}else{
							$('#chkFact').parents('.col-sm-4').find('small.text-muted').html(data.timbres+' folios disponibles');
						}
						$.unblockUI();
					},'json');
				}
			});

			$('tbody').on('click', '.btnFact', function(event) {
				event.preventDefault();
				id = $(this).parents('tr').data('ent');
				trp = $('#tbl-items [data-id="'+id+'"]').parents('tr');
				tdp = $(this).parents('td');
				blockPage();
				$.get($apiUrl+'facturaVenta/'+id, function(resp) {
					if(!resp.error){
						tdp.empty();
						tdp.append('<a href="<?= URL_ROOT ?>/venta/print/'+id+'?dl=1" target="_blank" data-popup="tooltip" title="PDF" class="btnPdf text-danger"><i class="mdi mdi-file-pdf"></i></a> ');
						tdp.append('<a href="<?= URL_ROOT ?>/venta/getXML/'+resp.cfdi_id+'" target="_blank" data-popup="tooltip" title="XML" class="btnXml text-muted"><i class="mdi mdi-file-xml"></i></a> ');
						tdp.append('<a href="#" data-popup="tooltip" title="Enviar" class="btnSend"><i class="mdi mdi-send"></i></a>');

						swal({
							type: "success",
							title: "¡Listo!",   
							text: "Se generó correctamente la factura.",   
							timer: 4000
						});
						window.open('<?= URL_ROOT ?>/venta/print/'+id+'?dl=1');
					}else{
						swal({
							type: "error",
							title: "Oops!",
							text: resp.msg,
							html: true
							//timer: 5000
						});
					}

					$.unblockUI();
				}, 'json');
			});

			$('tbody').on('click', '.btnSend', function(event) {
				event.preventDefault();
				id = $(this).parents('tr').data('ent');
				$('#envio-cfdi').val(id);
				$('#envio-mensaje').val('');
				mail = $(this).parent().data('mail');
				$('#envio-correo').val(mail);
