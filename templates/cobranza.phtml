			$('#btnSendFact').click(function() {
				$('.invalid-tooltip').remove();
				data = {id: $('#envio-cfdi').val(), 
						correo: $.trim($('#envio-correo').val()),
						mensaje: $.trim($('#envio-mensaje').val()) };

				$errLabel = $('<div class="invalid-tooltip"></div>');
				if(data.correo == ''){
					$errLabel.html('Debe ingresar el correo');
					$('#envio-correo').after($errLabel);
					$errLabel.show();
				}else if(data.mensaje == ''){
					$errLabel.html('Debe ingresar el mensaje');
					$('#envio-mensaje').after($errLabel);
					$errLabel.show();
				}else{
					blockPage();
					$.post($apiUrl+'sendCfdi', data, function(resp) {
						swal({
							type: "success",
							title: "¡Listo!",   
							text: "Se envió correctamente la factura.",   
							timer: 4000
						});
						$('#envio-cfdi').val(0);
						$('#envio-correo').val('');
						$('#envio-mensaje').val('');
						$('#frm-envio').modal('hide');
						$.unblockUI();
					}, 'json');
				}
			});
