					table = $('<table id="tbl-pagos" class="table table-sm"><thead><tr><td class="text-center">Folio</td><td class="text-center">Fecha</td><td class="text-center">Importe</td><td class="text-center">Forma de Pago</td><td class="text-center">Comentarios</td><td class="text-center">Estatus</td></tr></thead><tbody></tbody></table>').appendTo(td);
					$.get($apiUrl.replace('cobranza', 'venta_pago')+'getByVenta/'+id, function(resp) {
						if(resp.result.length>0) {
							$.each(resp.result, function(index, item) {
								tr = $('<tr data-id="'+item.id+'"></tr>');

								actions = $('<div class="pull-right"></div>');
								td = $('<td class="text-center"></td>');
