			$("#pago-cantidad").inputmask({
				alias: "numeric", groupSeparator: ',', digits: 2, digitsOptional: false, placeholder: '0'
			});

			$('#pago-tipo_pago_id').change(function() {
				btnComprobante = $('#btn-comprobante');
				if(!$(this).find('option:selected').data('comprobante')) {
					btnComprobante.addClass('hide');
					$('#pago-comprobante').removeAttr('src');
					$('#frm-pago .comprobante').addClass('hide');
				} else {
					btnComprobante.removeClass('hide');
				}
			});
			
			$('#btn-comprobante').click(function() {
				$('#pago-file').click();
			});

			$('#pago-file').change(function() {
				if(this.files && this.files[0]) {
					var reader = new FileReader();

					reader.onload = function(e) {
						$('#pago-comprobante').attr('src', e.target.result);
					}
					
					reader.readAsDataURL(this.files[0]);
					$('#frm-pago .comprobante').removeClass('hide');
				}
			});

			$('#btn-save-pago').click(function() {
				importe = $('#pago-cantidad').val();
				image = $('#pago-comprobante').attr('src');
				tipo_pago_id = $('#pago-tipo_pago_id').val();

				if(importe == '' || !parseFloat(importe)>0) {
					swal({
						type: "warning",
						title: "Datos insuficientes",
						text: "Debe ingresar la cantidad pagada",   
						timer: 4000
					});
				} else if(parseFloat(importe) > parseFloat($('#apartado-total').val())) {
					swal({
						type: "warning",
						title: "Cantidad invalida",
						text: "El importe no puede ser mayor que la cantidad restante",
						timer: 4000
					});
				} else if($('#pago-tipo_pago_id option:selected').data('comprobante')==1 && (image==null || image==undefined || image=='#')) {
					swal({
						type: "warning",
						title: "Datos insuficientes",
						text: "Debe ingresar el comprobante de pago",   
						timer: 4000
					});
				} else {
					<?php date_default_timezone_set("America/Mexico_City"); ?>
					date = '<?= date('Y-m-d H:i:s')?>'
					data = new FormData();
					data.append('venta_id', $('#venta-id').val());
					data.append('fecha', date);
					data.append('tipo_pago_id', tipo_pago_id);
					data.append('importe', importe);
					data.append('status', $('#pago-tipo_pago_id option:selected').data('automatico') == '0'? -1: 1);
					if($('#pago-tipo_pago_id option:selected').data('comprobante') == '1') {
						data.append('comprobante', $('#pago-file')[0].files[0]);
					}
					$.ajax({
						url: $apiUrl.replace('cobranza', 'venta_pago')+'add/',
						type: 'POST',
						data: data,
						contentType: false,
						processData: false,
						success: function(resp) {
							if($('#pago-tipo_pago_id option:selected').data('automatico') == 1) {
								swal({
									type: "success",
									title: "¡Listo!",   
									text: "Pago registrado con exito",
									timer: 4000
								});

								$('#frm-pago').modal('hide');
								getItems(0, $('#cont').val());
							} else {
								// data = {
								// 	url: "< ?= URL_ROOT ?>/ventas",
								// 	titulo: 'Pago Venta Folio '+$('#apartado-folio').val(),
								// 	cantidad: 1,
								// 	external_reference: resp.result,
								// 	precio: $('#pago-cantidad').val()
								// };
								// $.ajax({
								// 	url: "< ?= URL_API ?>pago/mercadopago",
								// 	type: 'POST',
								// 	data: data,
								// 	dataType: 'json',
								// 	async: false,
								// 	success: function(callback) {
								// 		location.href = callback.result;
								// 	}
								// });
							}
						}
					});
				}
			});

			$.get($apiUrl.replace('cobranza', 'tipo_pago')+'getAll/', function(tipos) {
				$('#pago-tipo_pago_id').empty();
				$.each(tipos.result, function(idx, item) {
					$('#pago-tipo_pago_id').append('<option value="'+item.id+'" data-comprobante="'+item.tiene_comprobante+'" data-automatico="'+item.es_automatico+'">'+item.nombre+'</option>');
				});
			}, 'json');
			
			$.get($apiUrl.replace('cobranza','sucursal')+'getAll/', function(data) {
				$.each(data.result, function(index, item) {
					$('#busSuc').append('<option value="'+item.id+'">'+item.nombre+'</option>');
				});
				if(data.result.length == 1) $('.sucursal').addClass('hide');

				$.get($apiUrl.replace('cobranza','cliente')+'getAll/0/0', function(data) {
					$.each(data.result, function(index, item) {
						$('#busCli').append('<option value="'+item.id+'">'+item.nombre+' '+item.apellidos+'</option>');
					});
					if(data.result.length == 1) { $('.cliente').addClass('hide'); }
					$('#item-cliente_id').select2();

					getItems(0,10); 
				},'json');
			},'json');

			$('#fechas, #busSuc, #busCli').change(function() {
				getItems(0, $('#cont').val());
			});

			function getItems(pag, lim){
				// blockPage();
				$('#btnFolio').popover('hide');
				$('#tbl-items tbody').empty();
				suc = $('#busSuc').val();
				cli = $('#busCli').val();
				var fechas = $('#fechas').data('daterangepicker');
				ini = fechas.startDate.format('YYYY-MM-DD');
				fin = fechas.endDate.format('YYYY-MM-DD');
				$.get($apiUrl.replace('cobranza', 'venta')+'rptCobranza/'+ini+'/'+fin+'/'+pag+'/'+lim+'/'+suc+'/'+cli, function(resp) {
					$.unblockUI();
					if(resp.total > 0){
						$.each(resp.result, function(index, item) {
							addRow(item);
						});
					} else { $('#tbl-items tbody').empty().append('<tr data-ent="0"><td colspan="8"><small>No existen deudas pendientes</small></td></tr>'); }

					doPagination(resp.total, lim, pag);
				});
			}

			function addRow(item){
				$('#tbl-items tbody tr[data-ent="0"]').remove();
				tr = $('<tr data-ent="'+item.id+'"></tr>');
				if($('#tbl-items [data-id="'+item.id+'"]').length > 0){
					tr = $('#tbl-items [data-id="'+item.id+'"]').parents('tr');
					tr.empty();
				}

				tr.append('<td class="text-center" data-id="'+item.id+'">'+item.folio+'</td>');
				tr.append('<td class="text-center">'+item.fecha+'</td>');
				cli = $('#busCli option[value="'+item.cliente_id+'"]').text();
				row = $('<td class="text-center">'+cli+'</td>').appendTo(tr);
				actions = $('<div class="pull-right"></div>').appendTo(row);
				<?php if(in_array(MOD_ACTION_PAGO_ADD, $permisos) || in_array(MOD_ACTION_PAGO_VALID, $permisos) || in_array(MOD_ACTION_PAGO_CANCEL, $permisos)) : ?>
					actions.append('<a href="#" data-popup="tooltip" title="Ver Pagos" class="btnInfoPago"><i class="fa fa-balance-scale"></i></a>');
					actions.append('&nbsp;|&nbsp;<a href="#" data-popup="tooltip" title="Pagar" class="btnPagar pull-right"><i class="fa fa-credit-card"></i></a>');
					// row.append(btnPagos).append(btnPagar);
				<?php endif; ?>

				btnFact = '--';
				<?php if(in_array(MOD_ACTION_FACT, $permisos)) : ?>
				if(item.cfdi_id == 0){
					btnFact = '<a href="#" data-popup="tooltip" title="Facturar" class="btnFact"><i class="mdi mdi-seal"></i> <small>Facturar</small></a> ';
				}else{
					btnFact = '<a href="<?= URL_ROOT ?>/venta/print/'+item.id+'?dl=1" target="_blank" data-popup="tooltip" title="PDF" class="btnPdf text-danger"><i class="mdi mdi-file-pdf"></i></a> ';
					btnFact += '<a href="<?= URL_ROOT ?>/venta/getXML/'+item.cfdi_id+'" target="_blank" data-popup="tooltip" title="XML" class="btnXml text-muted"><i class="mdi mdi-file-xml"></i></a> ';
					btnFact += '<a href="#" data-popup="tooltip" title="Enviar" class="btnSend"><i class="mdi mdi-send"></i></a>';
				}
				<?php endif; ?>
				tr.append('<td class="text-center" data-mail="'+item.mail+'">'+btnFact+'</td>');
				tr.append('<td class="text-right">$ '+item.total+'</td>');
				tr.append('<td class="text-right">$ '+item.pagado+'</td>');
				tr.append('<td class="text-right">$ '+item.restante+'</td>');
				
				fechaVenta = moment(item.fecha, 'YYYY-MM-DD');
				fechaVencimiento = fechaVenta.add(item.cliente.credito_dias, 'days').format('YYYY-MM-DD')
				diasRestantes = moment().diff(fechaVencimiento, 'days');
				tr.append('<td class="text-center">'+fechaVencimiento+'</td>');
					
				tr.addClass(diasRestantes>0? 'table-danger': diasRestantes==0? 'table-warning': 'table-success');
				$('#tbl-items tbody').append(tr);
			}

