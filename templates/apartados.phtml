	<script type="text/javascript">
		$(function(){
			$('#mnu-apart').addClass('active');
			$apartadoApiUrl = '<?= URL_API ?>apartado/';
			$apartadoDetalleApiUrl = '<?= URL_API ?>apartado_detalle/';
			$apartadoPagoApiUrl = '<?= URL_API ?>apartado_pago/';
			$sucursalApiUrl = '<?= URL_API ?>sucursal/';
			$clienteApiUrl  = '<?= URL_API ?>cliente/';
			$usuarioApiUrl  = '<?= URL_API ?>usuario/';
			$productoApiUrl  = '<?= URL_API ?>producto/';
			$ventaApiUrl  = '<?= URL_API ?>venta/';
			$tipoPagoApiUrl  = '<?= URL_API ?>tipo_pago/';

			$categoria_id = 0; $categoria_sku = '';

			<?php if(isset($_GET['preference_id'])) : ?>
				status = '<?= $_GET['status'] ?>';
				data = {
					status: (status=='success'? 1: (status=='pending'? 3: 2)),
					orden_id: '<?= $_GET['collection_id'] ?>'
				}
				$.ajax({
					url: $apartadoPagoApiUrl+"edit/<?= $_GET['external_reference'] ?>",
					type: 'PUT',
					data: data,
					dataType: 'json',
					success: function(resp) {
						switch(status) {
							case 'success':
								swal({
									type: "success",
									title: "¡Listo!",
									text: "Pago registrado con exito",
									timer: 4000
								});
								break;

							case 'pending':
								swal({
									type: "info",
									title: "Pago pendiente",
									text: "El pago está siendo validado",
									timer: 4000
								});
								break;

							default:
								swal({
									type: "warning",
									title: "Pago rechazado",
									text: "Intente realizar otro pago",   
									timer: 4000
								});
								break;
						}
					}
				});
			<?php endif; ?>
			
			page = 0;
			limit = $('#cont').val();

			$('.input-daterange-datepicker').daterangepicker({
				buttonClasses: ['btn', 'btn-sm'],
				applyClass: 'btn-primary',
				cancelClass: 'btn-inverse',
				maxDate: '<?= date('d/m/Y') ?>',
				locale: $dateRangeLocale,
				ranges: $dateRanges,
				alwaysShowCalendars: true,
				autoApply: true
			}, function(start, end, label) {
				getApartados();
			});

			$.get('<?= URL_API ?>venta/getInfoVenta/', function(info) {
				containerClient = $('#filter-client'); containerClient.empty().append('<option value="0">TODOS</option>');
				$.each(info.clientes, function(id, cliente) { containerClient.append('<option value="'+cliente.usuario_id+'">'+(cliente.nombre+' '+cliente.apellidos).toUpperCase()+'</option>'); });
				containerClient.find('option:first').prop('selected', true);
				if(info.clientes.length == 1) { containerClient.parents('.cliente').addClass('hide'); }

				if(parseInt('<?= $user->usuario_tipo_id ?>') == 1) {
					containerBranch = $('#filter-branch'); containerBranch.empty().append('<option value="0">TODAS</option>');
					$.each(info.sucursales, function(id, sucursal) { containerBranch.append('<option value="'+sucursal.id+'">'+sucursal.nombre.toUpperCase()+'</option>'); });
					containerClient.find('option:first').prop('selected', true);
					if(info.sucursales.length == 1) { containerBranch.parents('.sucursal').addClass('hide'); }
				} else {
					containerBranch = $('#filter-branch'); containerBranch.empty();
					sucursal = info.sucursal; containerBranch.append('<option value="'+sucursal.id+'">'+sucursal.nombre.toUpperCase()+'</option>');
					containerClient.find('option:first').prop('selected', true);
					containerBranch.parents('.sucursal').addClass('hide');
				}

				$.unblockUI();
			},'json');
			
			getApartados();
			function getApartados(){
				blockPage();
				$('#btnFolio').popover('hide');
				$('#tbl-items tbody tr').remove();
				
				var daterange = $('#filter-daterange').data('daterangepicker');
				ini = daterange.startDate.format('YYYY-MM-DD');
				fin = daterange.endDate.format('YYYY-MM-DD');
				suc = $('#filter-branch').val();
				// cli = $('#filter-client').val();
				seller = '<?= in_array(MOD_VALID_PAGO, $permisos) ?>' == 1? 0: '<?= $_SESSION['usuario']->id ?>';
				prod = $.trim($('#filter-prod').val());
				payment_status = $('#filter-status').val();
