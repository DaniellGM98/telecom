				function calcTotal(){
					tot = 0;
					$.each($('#tbl-prods tbody .importe'), function(index, elem) {
						imp = parseFloat($(elem).text());
						tot += imp;
					});
					sub = tot;
					iva = sub * parseInt('<?= $_SESSION['iva'] ?>') / 100;
					tot += iva;
					$('#apart-subtotal').val(sub.toFixed(2));
					$('#apart-iva').val(iva.toFixed(2));
					$('#apart-total').val(tot.toFixed(2));

					anticipo = $('#apart-anticipo').val()!=''? parseFloat($('#apart-anticipo').val()): 0;
					restante = tot - anticipo;
					$('#anticipo').val(anticipo.toFixed(2));
					$('#restante').val(restante.toFixed(2));
				}

