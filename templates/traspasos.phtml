			function getTrElement(tblName, tr) {
				container = $('<div></div>');
				trInfo = $('#'+tblName).DataTable().row(tr).data();
				$.each(trInfo, function(index, trInfoRow) {
					container.append(trInfoRow);
				});
				
				return container;
			}

			function setTrData(tblName, row, trElement) {
				arrContent = [];
				$.each(trElement.children(), function(index, element) { element = $(element);
					tagName = element.prop('tagName').toLowerCase();
					html = '<'+tagName;
					$.each(element[0].attributes, function(index, attr) {
						html += ' '+attr.name+'="'+attr.value+'"';
					});
					html += '>'+element.html()+'</'+tagName+'>';

					arrContent.push(html);
				});

				$('#'+tblName).DataTable().row(row).data(arrContent);
				swal({ type:"success", title:"¡Listo!", text:"Se guardaron los cambios correctamente.", timer:4000 });
			}

			function cleanTable(tbl) {
				if($.fn.dataTable.isDataTable('#'+tbl)) {
					table = $('#'+tbl).DataTable();
					table.destroy();
				}
				$("#nodata").remove();
			}

			function createTable(tbl, paging=true, arrColumnas=null, arrFechas=null, arrSucursal=null) {
				container = $('<div class="form-inline d-flex flex-row-reverse" style="overflow: visible"></div>');
				searchContainer = $('<div class="input-group col-sm-3"></div>').appendTo(container);
				search = $('<input type="text" id="bus" placeholder="Buscar por nombre" class="form-control">').appendTo(searchContainer);
				searchContainer.append('<input type="hidden" id="producto-id" value="0">');
				search.keyup(function(e) { $("#"+tbl+"_filter label input").val($.trim($(this).val())).trigger('keyup'); });
				search.on("search", function(evt) { $("#"+tbl+"_filter label input").val(undefined).trigger('keyup'); });
				if(tbl == 'tbl-traspaso') {
					fSucursalContainer = $('<div <?= intval($_SESSION['sucursal'])>0? 'class="hide"': '' ?>></div>').appendTo(container);
					fSucursal = $('<select class="selectpicker" id="sucursal-'+tbl+'" title="Sucursal" data-width="fit"></select>').appendTo(fSucursalContainer);
					fSucursal.append('<option class="form-control-sm" value="0">Todas</option>');
					<?php $sucursales = $todo->model->sucursal->getAll()->result; foreach($sucursales as $sucursal): ?>
					fSucursal.append('<option class="form-control-sm" value="<?= $sucursal->id ?>"><?= ucfirst(mb_strtolower($sucursal->nombre)) ?></option>');
					<?php endforeach; ?>
					fSucursal.selectpicker('val', '<?= $_SESSION['sucursal'] ?>');
					fSucursal.on('changed.bs.select', function(e, index) { blockPage();
						$.fn.dataTable.ext.search.pop();
						index--; if(index > 0) {
							$.fn.dataTable.ext.search.push(
								function(settings, data, dataIndex) {
									if(settings.nTable.id === 'tbl-traspaso') {
										return $($('#'+tbl).DataTable().row(dataIndex).node()).attr('data-sucursal') == index;
									}

									return true;
								}
							);
						}
						$('#'+tbl).DataTable().draw();
						$.unblockUI();
					});

					fFechasContainer = $('<div class="col-sm-3"></div>').appendTo(container);
					fFechasContainer2 = $('<div class="form-group"></div>').appendTo(fFechasContainer);
					fFechas = $('<div class="input-group"><div class="input-group-prepend"><span class="input-group-text"><i class="fa fa-calendar"></i></span></div><input type="text" class="form-control input-daterange-datepicker" id="fechas-'+tbl+'"></div>').appendTo(fFechasContainer2);
					if(arrFechas==null) { fFechas.find('#fechas-'+tbl).val('<?= date("d/m/Y", strtotime(date('d-m-Y'))).' - '.date('d/m/Y') ?>'); } else { fFechas.find('#fechas-'+tbl).val(arrFechas); }
					fFechas.find('#fechas-'+tbl).daterangepicker({ buttonClasses:['btn','btn-sm'], applyClass:'btn-primary', cancelClass:'btn-inverse', maxDate:'<?= date('d/m/Y') ?>', locale:$dateRangeLocale, ranges:$dateRanges, alwaysShowCalendars:true, autoApply:true },
						function(start, end, label) { getItems(); }
					);

					fColumnas = $('<select class="selectpicker" data-container="body" multiple data-selected-text-format="static" id="columns-'+tbl+'" title="Mostrar/Ocultar columnas" data-width="fit"></select>').appendTo(container);
					fColumnas.append('<option class="form-control-sm" value="0">Fecha</option>');
					fColumnas.append('<option class="form-control-sm" value="1">Empleado</option>');
					fColumnas.append('<option class="form-control-sm" value="2">Folio</option>');
					fColumnas.append('<option class="form-control-sm" value="3">Origen</option>');
					fColumnas.append('<option class="form-control-sm" value="4">Destino</option>');
					fColumnas.append('<option class="form-control-sm" value="5">No. Productos</option>');
					fColumnas.append('<option class="form-control-sm" value="6">Estado</option>');
					fColumnas.selectpicker('val', arrColumnas!=null? arrColumnas: ['0', '2', '3', '4', '6']);
					fColumnas.on('changed.bs.select', function(e, index) { blockPage();
						column = $('#'+tbl).DataTable().column(index);
						column.visible(!column.visible());
						$.unblockUI();
					});

					columnDefs = [
						{"orderable": true, "targets": [0], "visible": fColumnas.val().includes('0')},
						{"orderable": true, "targets": [1], "visible": fColumnas.val().includes('1')},
						{"orderable": true, "targets": [2], "visible": fColumnas.val().includes('2')},
						{"orderable": true, "targets": [3], "visible": fColumnas.val().includes('3')},
						{"orderable": true, "targets": [4], "visible": fColumnas.val().includes('4')},
						{"orderable": true, "targets": [5], "visible": fColumnas.val().includes('5')},
						{"orderable": true, "targets": [6], "visible": fColumnas.val().includes('6')},
						{"orderable": false, "targets": [7]},
					]
					order = [0, 'ASC'];
					dom = 'R<"#toolbar-'+tbl+'"l>frtip';
				} else if(tbl = 'tbl-productos') {
					columnDefs = [
						{"orderable": true, "targets": [0, 1], "visible": true},
						{"orderable": false, "targets": [2, 3]},
					]
					order = [0, 'ASC'];
					dom = 'R<"#toolbar-'+tbl+'">frt';
				}

				
				// icon = $('<div class="input-group-append"></div>').appendTo(searchContainer);
				// icon.append('<button type="button" class="btn btn-secondary btn-sm" id="btn-bus"><i class="fa fa-search"></i></button>');
				
				// search.find("#btn-bus").click(function(evt) { evt.preventDefault(); $("#"+tbl+"_filter label input").val($.trim($('#bus').val())).trigger('keyup'); });

				$('#tbl-traspaso_length').remove();
				$('#'+tbl).dataTable({
					'scrollX': false,
					'paging': paging,
					'pagingType': "full_numbers",
					'dom': dom,
					'columnDefs': columnDefs,
					'order': order
				});

				$('#toolbar-'+tbl).html(container).addClass('pull-right');
				$("#"+tbl+"_filter label").hide();
				$('#toolbar-tbl-traspaso').appendTo('#tbl-toolbar');
				$('#tbl-traspaso_length').appendTo('#tbl-toolbar');
				$('#tbl-traspaso_filter').appendTo('#tbl-toolbar');
			}
		});
		
	</script>
