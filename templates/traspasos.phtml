	<script type="text/javascript">
		$(function() {
			$('#mnu-prod').addClass('active');
			$apiUrl = '<?= URL_API ?>traspaso/';

			cleanTable('tbl-traspaso'); createTable('tbl-traspaso'); getItems(); cleanTable('tbl-productos'); createTable('tbl-productos', false);
			function getItems() { blockPage();
				$('#btnFolio').popover('hide');
				fechas = $('#fechas-tbl-traspaso').data('daterangepicker'); ini = fechas.startDate.format('YYYY-MM-DD'); fin = fechas.endDate.format('YYYY-MM-DD');
				arrColumnas = $('#columnas-tbl-traspaso').val(); arrFechas = fechas.startDate.format('DD/MM/YYYY')+' - '+fechas.endDate.format('DD/MM/YYYY'); arrSucursal = $('#sucursal-tbl-traspaso').val();
				cleanTable('tbl-traspaso'); $('#tbl-traspaso tbody').empty();
				$.get($apiUrl+'getAllBusca/'+ini+'/'+fin, function(traspasos) {
					$.each(traspasos.result, function(index, traspaso) {
						arrSucursales = [0, parseInt(traspaso.origen), parseInt(traspaso.destino)];
						// arrSucursales = [0]; arrSucursales.push(parseInt(traspaso.origen));
						if(arrSucursales.includes(parseInt('<?= $_SESSION['usuario']->sucursal_id ?>'))) {
							addTraspasoRow(traspaso);
						}
					});
					createTable('tbl-traspaso', true, arrColumnas, arrFechas, arrSucursal);
					$.unblockUI();
				});
			}

			function addTraspasoRow(info) {
				container = $('#tbl-traspaso tbody');
				container.find('tr[data-id="'+info.id+'"]').remove();
				tr = $('<tr data-id="'+info.id+'" data-sucursal="'+info.origen+'"></tr>').appendTo(container);

				tr.append('<td class="text-center"><small class="fecha">'+info.fecha+'</small></td>');
				tr.append('<td class="text-center"><small class="empleado">'+info.empleado+'</small></td>');
				tr.append('<td class="text-center"><small class="folio">'+info.folio+'</small></td>');
				tr.append('<td class="text-center"><small class="origen">'+info.origen_nombre+'</small></td>');
				tr.append('<td class="text-center"><small class="destino">'+info.destino_nombre+'</small></td>');
				tr.append('<td class="text-center"><small class="productos">'+info.sumaProductos+'</small></td>');
				tr.append('<td class="text-center"><small class="estado">'+(info.status==1? 'Realizado': (info.status==2? 'Pendiente por aprobar': 'Rechazado'))+'</small></td>');

				td = $('<td class="text-center"></td>').appendTo(tr)
				actions = $('<div class="pull-right"></div>').appendTo(td);
				actions.append('<a href="#" data-popup="tooltip" title="Ver detalles" class="btnInfoTraspaso"><i class="mdi mdi-eye"></i></a> ');
				<?php if(in_array(MOD_TRASPASOS_DEL, $permisos)) : ?>
				// actions.append('<a href="#" data-popup="tooltip" title="Cancelar" class="btnDelTraspaso"><i class="mdi mdi-delete" style="color:red;"></i></a>');
				<?php endif; ?>
			}
		
			$('#btnFolio').popover({
				placement: 'top',
				html:true,
				sanitize: false, 
				content:  '<div class="form"><div class="input-group"><input type="text" class="form-control form-control-sm" placeholder="Folio" id="buscafolioi"><div class="input-group-append"><button type="button" class="btn btn-secondary btn-sm" id="btn-busf"><i class="fa fa-search"></i></button></div></div></div>'
			}).on('click', function(e) {
				e.preventDefault();
				$('#buscafolioi').keyup(function(e) { if(e.keyCode == 13) { buscaFolio(); } });
				$('#btn-busf').click(function() { buscaFolio(); });
			});

			$('#btnFolio').on('shown.bs.popover', function () { $('#buscafolioi').val('').focus(); });

			function buscaFolio() {
				folio = $.trim($('#buscafolioi').val());
				if(folio != '') { blockPage();
					$('#btnFolio').popover('hide');
					arrColumnas = $('#columnas-tbl-traspaso').val(); arrFechas = $('#fechas-tbl-traspaso').val(); arrSucursal = $('#sucursal-tbl-traspaso').val();
					fechas = $('#fechas-tbl-traspaso').data('daterangepicker');
					ini = fechas.startDate.format('YYYY-MM-DD');
					fin = fechas.endDate.format('YYYY-MM-DD');
					cleanTable('tbl-traspaso'); $('#tbl-traspaso tbody').empty();
					$.get($apiUrl+'buscaFolio/'+folio+'/'+ini+'/'+fin, function(traspasos) {
						$.each(traspasos.result, function(index, traspaso) {
							arrSucursales = [0]; arrSucursales.push(parseInt(traspaso.origen));
							if(arrSucursales.includes(parseInt('<?= $_SESSION['usuario']->sucursal_id ?>'))) {
								addTraspasoRow(traspaso);
							}
						});
						createTable('tbl-traspaso', arrColumnas, arrFechas, arrSucursal);
						$.unblockUI();
					});
				}
			}

			$.get($apiUrl.replace('traspaso', 'sucursal')+'getAll/', function(sucursales) {
				<?php if(intval($_SESSION['sucursal']) == 0): ?>$('#traspaso-origen').append('<option value="0">Selecciona una opción</option>');<?php endif; ?>
				$('#traspaso-destino').append('<option value="0">Selecciona una opción</option>');
				$.each(sucursales.result, function(index, sucursal) {
					arrSucursales = [0]; arrSucursales.push(parseInt(sucursal.id));
					if(arrSucursales.includes(parseInt('<?= $_SESSION['usuario']->sucursal_id ?>'))) {
						$('#traspaso-origen').append('<option value="'+sucursal.id+'"'+(parseInt('<?= $_SESSION['usuario']->sucursal_id ?>')==parseInt(sucursal.id)? ' selected="selected"': '')+'>'+sucursal.nombre+'</option>');
					}
					$('#traspaso-destino').append('<option value="'+sucursal.id+'" class="hide">'+sucursal.nombre+'</option>');
				});
			}, 'json');

			$('#traspaso-origen').change(function() {
				$('.invalid-tooltip').remove();
				value = $(this).val();
				$('#traspaso-destino').val(0);
				$('#traspaso-destino option').removeClass('hide');
				if(value == 0) { $('#traspaso-destino option:not([value="0"])').addClass('hide'); }
				else { $('#traspaso-destino option[value="'+value+'"]').addClass('hide'); }

				$.get('<?= URL_ROOT ?>/traspaso/sigFolio/'+value, function(folio) {
					$('#traspaso-folio').val(folio);
				}, 'json');
			});

			function addProductoRow(producto) {
				container = $('#tbl-productos tbody');
				cleanTable('tbl-productos');

				container.find('tr[data-id="'+producto.id+'"]').remove();
				tr = $('<tr data-id="'+producto.id+'"></tr>').appendTo(container);
				tr.append('<td class="text-left"><small class="producto">'+producto.producto+'</small></td>');
				tr.append('<td class="text-left"><small class="arrSku">'+((producto.sku==null || producto.sku.length==0)? '': producto.sku)+'</small></td>');
				tr.append('<td class="text-center"><small class="cantidad">'+producto.cantidad+'</small></td>');
				
				tr.append('<td class="pull-right"><div><a href="#" data-popup="tooltip" title="Eliminar" class="btnDelProducto"><i class="mdi mdi-delete" style="color:red;"></i></a></div></td>');

				createTable('tbl-productos', false);
			}

			$('tbody').on('click', '.btnInfoTraspaso', function(e) { blockPage();
				e.preventDefault();
				$.get($apiUrl+'get/'+$(this).parents('tr').data('id'), function(traspaso) {
					cleanTable('tbl-productos'); $('#tbl-productos tbody').empty(); createTable('tbl-productos');
					if(traspaso.response) { traspaso = traspaso.result;
						$('#traspaso-origen').val(traspaso.origen).prop('disabled', true);
						$('#traspaso-destino').val(traspaso.destino).prop('disabled', true);
						$('#traspaso-folio').val(traspaso.folio).prop('disabled', true);
						$('#btnSaveTraspaso').parent().addClass('hide').prev('button').html('Cerrar');
						$('#btnAddProducto').parent().addClass('hide');
						$('#frm-traspaso .modal-title').html('<i class="mdi mdi-information"></i> Información traspaso')

						$.each(traspaso.detalles, function(index, detalle) {
							addProductoRow(detalle);
						});
						$('#tbl-productos tbody tr').find('.btnDelProducto').remove();
						$('#frm-traspaso').modal('show');
						setTimeout(() => { $('#productos-tab').tab('show'); $.unblockUI(); }, 1000);
					} else { $.unblockUI(); }
				}, 'json')
			});

<?php if(in_array(MOD_TRASPASOS_ADD, $permisos)) : ?>
			// $('#frm-traspaso').on('shown.bs.modal', function () { $('#traspaso-folio').focus(); });
