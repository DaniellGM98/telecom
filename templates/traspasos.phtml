			function addProducto() {
				if($('.msgStock').length == 0) {
					$('.invalid-tooltip').remove();
					$('#frm-traspaso small.text-danger').html('');
					data = { id: $('#producto-producto_id').val(), producto: $('#producto-producto').val(), cantidad: $('#producto-cantidad').val()};
					if($('#sku').is(':visible')) { data.sku = $('#producto-sku').val(); }
	
					$errLabel = $('<div class="invalid-tooltip"></div>');
					if(data.id == 0) {
						$errLabel.html('Debe seleccionar el producto a traspasar');
						$('#producto-producto').after($errLabel).focus();
						$errLabel.show();
					} else if(!$('#sku').is(':visible') && (data.cantidad.length==0 || parseInt(data.cantidad)==0)) {
						$errLabel.html('Debe ingresar la cantidad a traspasar');
						$('#producto-cantidad').after($errLabel).focus();
						$errLabel.show();
					} else if($('#sku').is(':visible') && data.sku.length==0) {
						$errLabel.html('Debe seleccionar los '+$('label[for="producto-sku"]').text()+' a traspasar');
						$('#producto-sku').after($errLabel).focus();
						$errLabel.show();
					} else {
						if(!prodExists(data.id)) {
							url = '2/' + $('#traspaso-origen').val() + '/' + data.id;
							if($('#sku').is(':visible')) { url += '/' + data.sku; }
							$.get('<?= URL_API ?>traspaso/getAll/'+url, function(traspasos) {
								if(traspasos.result.length==0 || (!$('#sku').is(':visible') && parseInt(traspasos.suma)+parseInt(data.cantidad)<=parseInt(traspasos.stock))) {
									if(data.sku != undefined) { data.sku = data.sku.join(', '); }
									addProductoRow(data);
									clearDataProducto();
									$('#frm-producto').modal('hide');
									setTimeout(function(){ $('#productos-tab').click(); }, 600);
								} else {
									swal({ type:"warning", title:"Oops!", text:'El producto seleccionado cuenta con traspasos pendientes<br>Confirma o cancela dichas solicitudes e intentalo una vez más', html: true, timer:4000 }); 
								}
							}, 'json');
						}
					}
				}
			}

