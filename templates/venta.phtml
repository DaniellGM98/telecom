							data.status = 1;
							$.post('<?= URL_API ?>cliente/add/', data, function(resp) {
								if(resp.response) { data.id = resp.result
									$('#external-sale-cliente_id').append('<option value="'+data.id+'">'+data.nombre+' '+data.apellidos+'</option>');
									$('#external-sale-cliente_id').val(data.id);
									$('.cliente').removeClass('hide');
									$('#external-client-id').val(0);
									$('#frm-external-sale-cliente').modal('hide');
									$('#frm-external-sale').modal('show');
									$('#chkFact').prop('checked', false);
									swal({ type: "success", title: "¡Listo!", text: "Se arego el cliente correctamente.", timer: 4000 });
								} else { swal({ type: "warning", title: "Oops!", text: resp.message, timer: 4000 }); }
								$.unblockUI();
							},'json');
						}
					});
				<?php endif; ?>

				var fndProds = new Bloodhound({
					initialize: false,
					datumTokenizer: Bloodhound.tokenizers.obj.whitespace('value'),
					queryTokenizer: Bloodhound.tokenizers.whitespace,
					remote: {
						wildcard: '%QUERY',
						url: '<?= URL_API ?>producto/getProductosServicios/%QUERY',
						replace: function(url, uriEncodedQuery) {
							sucursal_id = $('#external-sale-sucursal_id').val();
							prod_categoria_id = $('#external-item-prod_categoria_id').val();
							if(!sucursal_id) return url.replace('%QUERY', uriEncodedQuery);
							if(!prod_categoria_id) return url.replace('%QUERY', uriEncodedQuery);
							// return url + uriEncodedQuery + '/' + sucursal_id + '/1';
							return url.replace('%QUERY', uriEncodedQuery) + '/' + encodeURIComponent(sucursal_id) + '/1/'+encodeURIComponent(prod_categoria_id);
						}
					}
				});

				$('#external-sale-prod-search').typeahead({ hint: true, highlight: true, minLength: 3 }, { limit: 60, display: 'identificador', source: fndProds });
				$('#external-sale-prod-search').change(function() {  $('.invalid-tooltip').remove(); $('#frm-external-sale small.text-danger').html('');
					if($.trim($(this).val()) == '') {
						$('#external-sale-prod-id').val(0);
						$categoria_id = 0;
						$categoria_sku = '';
					}
				});

				function external_sale_prodExists(prodId, prodTipo) {
					if($('#tbl-external-sale-prods > tbody > [data-id="'+prodId+'"][data-tipo="'+prodTipo+'"]').length > 0) {
						$errLabel = $('<div class="invalid-tooltip">Ya existe el producto</div>');
						$('#frm-external-sale small.text-danger').html('Ya existe el producto');
						$('#external-sale-prod-search').after($errLabel).select().focus();
						$errLabel.show();
						return true;
					}
					return false;
				}

				$('#external-sale-prod-search').bind('typeahead:select', function(ev, suggestion) { $('.invalid-tooltip').remove(); $('#frm-external-sale small.text-danger').html('');
					$('#external-sale-prod-id').val(suggestion.id);
					$('#external-sale-prod-tipo').val(suggestion.tipo);
					if(!external_sale_prodExists(suggestion.id, suggestion.tipo)) { blockPage();
						$('#external-sale-prod-listap').empty();
						$('#external-sale-prod-stock').val(suggestion.stock);
						$('#external-sale-prod-costo').val(0.00);
						if(suggestion.tipo == 'producto') {
							$categoria_id = suggestion.prod_categoria_id;
							$categoria_sku = suggestion.sku_nombre!=null? suggestion.sku_nombre.toUpperCase(): '';
							$('#external-sale-prod-listap').prop('disabled', false).empty();
							$.get('<?= URL_API ?>venta/getPrecio/'+suggestion.id+'/'+$('#external-sale-sucursal_id').val(), function(data) {
								$.each(data.listas, function(index, lista) { $('#external-sale-prod-listap').append('<option value="'+lista.precio+'">'+lista.nombre+'</option>'); });
								$('#external-sale-prod-stock').val(data.stock);
								$('#external-sale-prod-listap').trigger('change');
								$.get('<?= URL_API ?>prod_categoria/get/'+suggestion.prod_categoria_id, function(categoria) {
									if(parseInt(categoria.result.tiene_sku) == 1) { 
										$('#imei').removeClass('hide').find('textarea').attr('placeholder', categoria.result.sku_nombre.toUpperCase());
										$('#external-sale-prod-cantidad').prop('readonly', true);
										$('#external-sale-prod-imei').val('').focus();
									} else {
										$('#imei').addClass('hide');
										$('#external-sale-prod-cantidad').prop('readonly', false).focus().val(1).trigger('change');;
									}
									$.unblockUI();
								},'json');
							},'json');
						} else {
							$('#external-sale-prod-listap').prop('disabled', true).empty();
							$('#external-sale-prod-costo').val(suggestion.precio).trigger('change');
							$('#external-sale-prod-cantidad').focus().val(1).trigger('change');
							$.unblockUI();
						}
					} 
				});

				$('#external-sale-prod-search').keyup(function(event) {
					if(event.keyCode == 8 || event.keyCode == 46) {
						$('#external-sale-prod-id').val(0);
						$categoria_id = 0;
						$categoria_sku = '';
					}
				});

				$('#external-sale-prod-listap').change(function() { $('#external-sale-prod-costo').val($(this).val()).trigger('change'); });
				$("#external-sale-prod-cantidad").inputmask({ alias: "numeric", digits: 0});
				$("#external-sale-prod-costo").inputmask({ alias: "numeric", groupSeparator: ',', digits: 2, digitsOptional: false, placeholder: '0' });

				function external_sale_calcImporte() {
					if(!$('#external-sale-prod-cantidad').prop('readonly')) { cant = parseInt($('#external-sale-prod-cantidad').val()); }
					else { cant = $('#external-sale-prod-imei').val().split('\n').filter(imei => $.trim(imei).length > 0).length; }
					if(isNaN(cant)) cant = 0;

					costo = parseFloat($('#external-sale-prod-costo').val());
					if(isNaN(costo)) costo = 0;

					importe = cant * costo;
					$('#external-sale-prod-importe').val(importe.toFixed(2));
				}

				$("#external-sale-prod-cantidad, #external-sale-prod-costo").change(function() {
					external_sale_calcImporte();
				});

				function external_sale_agregarProducto_validStock(cant) {
					stock = parseInt($.trim($('#external-sale-prod-stock').val()));
					if(cant > stock) { swal({ type:"warning", title:"Stock insuficiente", text:"Solo existen "+stock+" productos en stock", html:true, timer:4000 }); }
					else {
						if($('#tbl-external-sale-prods tbody').find('tr[data-tipo="servicio"], tr[data-tipo="paquete"]').length > 0) {
							$.each($('#tbl-external-sale-prods tbody').find('tr[data-tipo="servicio"], tr[data-tipo="paquete"]'), function(trIndex, trRow) { trRow = $(trRow); trRowId = trRow.attr('data-id');
								$.each($('.servicio-info[data-id="'+trRowId+'"]').find('tr[data-id="'+$('#external-sale-prod-id').val()+'"]'), function(index, trServicio) { trServicio = $(trServicio);
									cant += parseInt(trServicio.find('td:eq(1)').text()) * parseInt(trRow.find('td:eq(1)').text());
								});
								if(cant > stock) { swal({ type:"warning", title:"Stock insuficiente", text:"Solo existen "+stock+" productos en stock<br />Revisa la información de tus servicios/paquetes", html:true, timer:4000 }); }
								else { external_sale_addProductoServicioRow(); }
							});
						} else { external_sale_addProductoServicioRow(); }
					}
				}

				function external_sale_addProductoServicioRow() {
					prod = $.trim($('#external-sale-prod-search').val());
					cant = parseInt($.trim($('#external-sale-prod-cantidad').val()));
					costo = $.trim($('#external-sale-prod-costo').val());
					imp = $.trim($('#external-sale-prod-importe').val());
					arrImei = $.trim($('#external-sale-prod-imei').val());
					
					if(prod.length > 0 && (cant>0 || $('#external-sale-prod-cantidad').prop('readonly')) && costo.length > 0 && imp.length > 0 && $('#external-sale-prod-id').val() > 0) {
						if(!external_sale_prodExists($('#external-sale-prod-id').val(), $('#external-sale-prod-tipo').val())) {
							$.get('<?= URL_API ?>producto/get/'+$('#external-sale-prod-id').val(), function(producto) { producto = producto.result;
								$.get('<?= URL_API ?>prod_categoria/get/'+producto.prod_categoria_id, function(categoria) { categoria = categoria.result;
									container = $('#tbl-external-sale-prods tbody').first();
									trp = $('<tr data-id="'+$('#external-sale-prod-id').val()+'" data-tipo="'+$('#external-sale-prod-tipo').val()+'"></tr>').appendTo(container);
									trp.append('<td><small>'+prod+'</small></td>');
									trp.append('<td class="text-center">'+($.isNumeric(cant)? cant: arrImei.split('\n').length)+'</td>');
									trp.append('<td class="text-right precio">'+costo+'</td>');
									trp.append('<td class="text-right importe">'+imp+'</td>');
									
									td = $('<td></td>').appendTo(trp);
									actions = $('<div class="pull-right actions"></div>').appendTo(td);
									if(categoria.regalo == 1) {
										actions.append('<button class="btn btn-sm btn-link tnl_external_sale_btnRegalo" type="button"><i class="fa fa-gift"></i></button> ');
									}
									if($('#external-sale-prod-tipo').val()=='servicio' || $('#external-sale-prod-tipo').val()=='paquete') {
										actions.append('<button class="btn btn-sm btn-info tnl_external_sale_btnInfo" type="button"><i class="fa fa-info"></i></button> ');
									}
									actions.append('<button class="btn btn-sm btn-danger tbl-external-servicio-prodDel" type="button"><i class="fa fa-trash"></i></button>');
									
									if(arrImei!='') {
										container.append('<tr class="imei" data-id="'+$('#external-sale-prod-id').val()+'"><td colspan="5"><textarea disabled="disabled" class="form-control">'+arrImei+'</textarea></td></tr>');
										$('#imei').addClass('hide');
									}

									external_sale_calcTotal();
									external_sale_clearData();
									$('#external-sale-prod-search').focus();
									$('#external-sale-prod-imei').val(undefined);
									$('#external-sale-descuento').removeAttr('readonly').trigger('change');
								}, 'json');
							}, 'json');
						}
					}
				}

				$('tbody').on('click', '.tnl_external_sale_btnRegalo', function(event) { event.preventDefault();
					tr = $(this).parents('tr');
					tr.addClass('table-info');
					tr.find('.precio').attr('data-org', tr.find('.precio').text()).html('0.00');
					tr.find('.importe').attr('data-org', tr.find('.importe').text()).html('0.00');
					tr.find('.actions').prepend('<button class="btn btn-sm btn-warning tnl_external_sale_btnRegaloCancel" type="button"><i class="fa fa-dollar"></i></button>')

					$(this).remove();
					external_sale_calcTotal();
					$('#external-sale-descuento').trigger('change');
				});

				$('tbody').on('click', '.tnl_external_sale_btnRegaloCancel', function(event) { event.preventDefault();
					tr = $(this).parents('tr');
					tr.removeClass('table-info');
					tr.find('.precio').html(tr.find('.precio').attr('data-org')).removeAttr('data-org');
					tr.find('.importe').html(tr.find('.importe').attr('data-org')).removeAttr('data-org');
					tr.find('.actions').prepend('<button class="btn btn-sm btn-link tnl_external_sale_btnRegalo" type="button"><i class="fa fa-gift"></i></button>')
					
					$(this).remove();
					external_sale_calcTotal();
					$('#external-sale-descuento').trigger('change');
				});

				function external_sale_addProducto() { $('#frm-external-sale small.text-danger').html('');
					prod = $.trim($('#external-sale-prod-search').val());
					cant = parseInt($.trim($('#external-sale-prod-cantidad').val()));
					costo = $.trim($('#external-sale-prod-costo').val());
					imp = $.trim($('#external-sale-prod-importe').val());
					arrImei = $.trim($('#external-sale-prod-imei').val()).split('\n').filter(imei => $.trim(imei).length>0);

					if(!external_sale_prodExists($('#external-sale-prod-id').val(), $('#external-sale-prod-tipo').val()) && (prod.length == 0 || $('#external-sale-prod-id').val() == 0)) {
						$('#frm-external-sale small.text-danger').html('Debe elegir un producto de la lista');
						$('#external-sale-prod-search').focus();
					} else if((cant.length == 0 || cant == 0 || isNaN(cant)) && !$('#external-sale-prod-cantidad').prop('readonly')) {
						$('#frm-external-sale small.text-danger').html('Debe ingresar la cantidad');
						$('#external-sale-prod-cantidad').focus();
					} else if($('#imei:visible').length>0 && arrImei=='') {
						$('#frm-external-sale small.text-danger').html('Debe proporcionar todos los '+$('#external-sale-prod-imei').attr('placeholder')+' de los productos');
						$('#external-sale-prod-imei').focus();
					} else {
						if($('#external-sale-prod-tipo').val() == 'producto') {
							if($('#imei:visible').length>0) { errores = [];
								$('#external-sale-prod-imei').val('');
								arrSku = []; counter = 0; agregar = true; $agregado = false;
								$.each(arrImei, function(index, item) {
									$.get('<?= URL_API ?>prod_entrada_detalle/buscarPorSku/'+item+'/'+$categoria_id+'/'+$('#external-sale-prod-id').val()+'/<?= $_SESSION['sucursal'] ?>', function(detalle) {
										if(detalle.response) {
											$.get('<?= URL_API ?>venta/verificarTraspaso/'+item+'/<?= $_SESSION['sucursal'] ?>', function(veriTraspa){
												console.log(veriTraspa.disponible)
												if(veriTraspa.disponible){
													agregar = false; errores.push($categoria_sku+' ('+item+'): se encuentra en traspaso'); arrImei.splice(index, 1);
													$('#frm-external-sale small.text-danger').html(errores.join('<br>'))
												}else{
													$.get('<?= URL_API ?>prod_salida_detalle/buscarPorSku/'+item+'/'+$categoria_id, function(detalle) { counter++;
														if(!detalle.response) {
															if(!arrSku.includes(item)) { arrSku.push(item);
																if(counter==arrImei.length && agregar) { $agregado = true;
																	$('#external-sale-prod-imei').val(arrSku.join('\n')+'\n');
																	
																	external_sale_calcImporte();
																	external_sale_agregarProducto_validStock(cant);
																}
															} else { agregar = false; errores.push($categoria_sku+' ('+item+'): duplicado en la venta'); }
														} else { agregar = false; errores.push($categoria_sku+' ('+item+'): agotado'); }
														$('#frm-external-sale small.text-danger').html(errores.join('<br>'));
														if(!$agregado) {
															$('#external-sale-prod-imei').val(arrSku.join('\n')+'\n');
															external_sale_calcImporte();
														}
													}, 'json');
												}
											},'json')
										
										} else { agregar = false; errores.push($categoria_sku+' ('+item+'): no existe'); arrImei.splice(index, 1); }
										$('#frm-external-sale small.text-danger').html(errores.join('<br>'));
									}, 'json');
								});
							} else {
								external_sale_agregarProducto_validStock(cant);
							}
						} else if($('#external-sale-prod-tipo').val()=='servicio' || $('#external-sale-prod-tipo').val()=='paquete') {
							$.get('<?= URL_API ?>prod_servicio/getByServicio/'+$('#external-sale-prod-id').val(), function(prod_servicio) {
								if(prod_servicio.result.length > 0) {
									$continuar = true;	$prodSinStock = undefined;	$contador = 0;
									$.each(prod_servicio.result, function(index, item) {
										cant = parseInt($('#external-sale-prod-cantidad').val()) * parseInt(item.cantidad);
										$.each($('#tbl-external-sale-prods tbody tr:not(.servicio-info)'), function(trIndex, trRow) { trRow = $(trRow); trRowId = trRow.attr('data-id'); trRowTipo = trRow.attr('data-tipo');
											if(trRow.parents('.servicio-info').length == 0) {
												if(trRowTipo=='producto' && trRowId==item.producto_id) {
													cant += parseInt(trRow.find('td:eq(1)').text());
												} else if(['servicio', 'paquete'].includes(trRowTipo)) { trRowNext = trRow.next('.servicio-info'); trRowProducto = trRowNext.find('tr[data-id="'+item.producto_id+'"]');
													if(trRowProducto.length > 0) {
														cant += parseInt(trRow.find('td:eq(1)').text()) * parseInt(trRowProducto.find('td:eq(1)').text());
													}
												}
											}
										});
										
										$.get('<?= URL_API ?>prod_kardex/getStockSuc/'+$('#external-sale-sucursal_id').val()+'/'+item.producto_id, {prodInfo: item, tipo: prod_servicio.tipo, cantidad: cant}, function(prod_kardex) {
											$contador++;
											if(prod_kardex.cantidad > parseInt(prod_kardex.result.final)) {
												$continuar = false; 
												$prodSinStock = {
													prodInfo: prod_kardex.prodInfo, 
													tipo: prod_kardex.tipo,
													cantidad: prod_kardex.cantidad,
													stock: prod_kardex.result.final
												};
											}
											if($contador == prod_servicio.result.length) {
												if($continuar) {
													external_sale_addProductoServicioRow();
													external_sale_mostrarDetalleServicio();
												} else {
													swal({
														type: "warning",
														title: "Stock insuficiente",
														text: "No hay suficiente stock del siguiente producto: <br /> "+$prodSinStock+"<br /><br /> ¿Deseas eliminar/modificar algún producto del "+$prodSinStock.tipo+"?",
														html: true,
														showCancelButton: true,
														cancelButtonText: "No",
														confirmButtonColor: "#DD6B55",
														confirmButtonText: "Si, modificar",
														closeOnConfirm: true,
													}, function() {
														external_sale_mostrarDetalleServicio($prodSinStock.prodInfo);
													});
												}
											}
										}, 'json');
									});
								} else {
									external_sale_addProductoServicioRow();
									external_sale_mostrarDetalleServicio();
								}
							}, 'json');
						}
					}
				}

				// $("#external-sale-prod-cantidad, #external-sale-prod-costo").keyup(function(event) { if(event.keyCode == 13) external_sale_addProducto(); });
				$('#external-sale-prodAdd').click(function() { external_sale_addProducto(); });

				$('#tbl-external-sale-prods').on('click', '.tnl_external_sale_btnInfo', function(e) { e.preventDefault();
					if($('#tbl-external-sale-prods').find('.stock-insufficient').length != 0) { swal({type: "warning", title: "No se puede realizar la acción", text: 'Finaliza o cancela la modificación actual para continuar', html: true, timer: 4000}); }
					else { external_sale_mostrarDetalleServicio(undefined, $(this).parents('tr').attr('data-id')); }
				});

				function external_sale_mostrarDetalleServicio(prodSinStock=undefined, index=undefined) {
					if(prodSinStock!=undefined) { external_sale_addProductoServicioRow(); }
					container = $('#tbl-external-sale-prods tbody');
					trParent = index==undefined? container.find('tr:not(.servicio-info)').last(): container.find('tr[data-id="'+index+'"]');
					next = trParent;
					id = trParent.attr('data-id');
					
					if($('.servicio-info[data-id="'+id+'"]').length>0 && !$('.servicio-info[data-id="'+id+'"]').hasClass('hide')) {
						$('.servicio-info[data-id="'+id+'"]').addClass('hide');
					} else if($('.servicio-info[data-id="'+id+'"]').length > 0) {
						$('.servicio-info').addClass('hide');
						$('.servicio-info[data-id="'+id+'"]').removeClass('hide');
					} else {
						$('.servicio-info').addClass('hide');
						row = $('<tr class="servicio-info table-success hide" data-id="'+id+'"></tr>');
						td = $('<td colspan="5"></td>').appendTo(row);
						td.append('<a href="#" data-popup="tooltip" title="Ocultar" class="tbl-external-sale-btnCloseServicioInfo btn close" style="color:red;">&times;</a>');
						table = $('<table class="table table-sm table-borderless"><thead><tr class="table-success"><td class="text-center">Producto</td><td class="text-center">Cantidad</td><td class="text-center">Precio</td><td class="text-center">Importe</td><td class="text-center"></td></tr></thead><tbody></tbody></table>').appendTo(td);
						$.get('<?= URL_API ?>prod_servicio/getByServicio/'+id, function(resp) {
							if(resp.response) {
								$.each(resp.result, function(index, item) {
									tr = $('<tr data-id="'+item.producto_id+'" data-tipo="producto" data-servicio="'+id+'" class="table-success"></tr>').appendTo(table);

									tr.append('<td class="text-left"><small>'+item.producto+'</small></td>');
									tr.append('<td class="text-center"><small>'+item.cantidad+'</small></td>');
									tr.append('<td class="text-right"><small>'+item.precio+'</small></td>');
									tr.append('<td class="text-right"><small>'+(parseInt(item.cantidad)*parseFloat(item.precio)).toFixed(2)+'</small></td>');

									td = $('<td class="text-center"></td>').appendTo(tr);
