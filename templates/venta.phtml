<script type="text/javascript">
	// window.onload = function() {
	window.addEventListener('load', function() {
		$(function () {
			$categoria_id = 0; $categoria_sku = ''; $contador = 0; $continuar = 0;
			<?php if(in_array(MOD_VENTA_ADD, $permisos)) : ?>
				$('#frm-external-sale').on('shown.bs.modal', function () { 
					header = $(this).find('.modal-header');
					if($('#external-sale-btnSave').text() == 'Siguiente') {
						header.css('padding-bottom', '');
						header.find('.row').last().addClass('hide');
					} else if($('#external-sale-btnSave').text() == 'Guardar') {
						header.css('padding-bottom', 0);
						header.find('.row').last().removeClass('hide');
					}
				});

				$('#frm-external-sale').on('hidden.bs.modal', function () { $('#external-sale-descuento').attr('readonly', 'readonly'); });
				// $('#frm-external-sale').on('hide.bs.modal', function () { $('#external-sale-tab').click(); });

				$('#btnAddVenta, #btnAddVenta-ext').click(function(e) { e.preventDefault(); blockPage(); clearVentaData();
					$('#external-sale-cliente_id, #external-sale-sucursal_id, #external-sale-empleado_id, #external-item-prod_categoria_id').prop('disabled', false).empty();
					$.get('<?= URL_API ?>venta/getInfoVenta/', function(info) {
						$('#external-sale-empleado_id').append('<option value="0">Seleccionar</option>');
						$.each(info.empleados, function(id, empleado) { $('#external-sale-empleado_id').append('<option value="'+empleado.usuario_id+'">'+(empleado.nombre+' '+empleado.apellidos).toUpperCase()+'</option>'); });
						//$('#external-sale-empleado_id option[value="<?= $user->id ?>"]').prop('selected', true);
						$('#external-sale-empleado_id').select2();

						$.each(info.clientes, function(id, cliente) { $('#external-sale-cliente_id').append('<option value="'+cliente.usuario_id+'">'+(cliente.nombre+' '+cliente.apellidos).toUpperCase()+'</option>'); });
						$('#external-sale-cliente_id option:contains(GENERAL):first').prop('selected', true);
						if(info.clientes.length == 1) { $('.cliente').addClass('hide'); }
						$('#external-sale-cliente_id').select2();

						$('#external-item-prod_categoria_id').append('<option value="0">TODAS</option>');
						$.each(info.categorias, function(index, categoria) { $('#external-item-prod_categoria_id').append('<option value="'+categoria.id+'">'+categoria.nombre.toUpperCase()+'</option>'); });

						if(parseInt('<?= $user->usuario_tipo_id ?>') == 1) {
							$.each(info.sucursales, function(id, sucursal) { $('#external-sale-sucursal_id').append('<option value="'+sucursal.id+'">'+sucursal.nombre.toUpperCase()+'</option>'); });
							$('#external-sale-sucursal_id option:first').prop('selected', true);
							if(sucursales.result.length == 1) { $('.sucursal').addClass('hide'); }
						} else {
							sucursal = info.sucursal; $('#external-sale-sucursal_id').append('<option value="'+sucursal.id+'">'+sucursal.nombre.toUpperCase()+'</option>');
							$('#external-sale-sucursal_id option[value="<?= $_SESSION['sucursal'] ?>"]').prop('selected', true);
							$('.sucursal').addClass('hide');
						}

						getSigFolio();
						$('#frm-external-sale').modal('show');
						$.unblockUI();
					},'json');
				});

				function getSigFolio() {
					$.get('<?= URL_ROOT ?>/venta/sigFolio/'+$('#external-sale-sucursal_id').val(), function(data) { folio = data.folio;
						$('#chkFact').prop('disabled', false);
						if(data.timbres == 0) {
							$('#chkFact').prop('disabled', true);
							$('#chkFact').parents('.col-sm-4').find('small.text-muted').html('No cuenta con folios para facturar');
						}else{
							$('#chkFact').parents('.col-sm-4').find('small.text-muted').html(data.timbres+' folios disponibles');
						}

						// $('#external-sale-folio').val($('#external-sale-sucursal_id').val().toString().padStart(3,0)+folio.toString().padStart(6,0));
						$('#external-sale-folio').val(folio);
						$('#external-sale-id').val(undefined);
						$('#tbl-external-sale-prods tbody').empty();
						$('#btn-external-sale-add-cliente, #tbl-external-sale-prods tfoot tr:first').removeClass('hide');
						$('#external-sale-descuento').prop('readonly');
						$('#external-sale-tab').click().trigger('click');
						$('#external-sale-cliente_id').trigger('change');

					},'json');
				}

				$('#external-sale-sucursal_id').change(function() {
					clearVentaData();
					getSigFolio();
				});

				/*$('#external-item-prod_categoria_id').change(function() {
					clearVentaData();
				});*/

				<?php if(in_array(MOD_VENTA_ADD, $permisos) && in_array(MOD_CLIENTE_ADD, $permisos)) : ?>
					function clearExternalClienteData() {
						$('.invalid-tooltip').remove();
						$('#frm-external-sale-cliente input').val('');
						$('#external-client-id').val(0);
					}

