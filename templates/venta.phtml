				$('#external-payment-comments-btnSave').click(function() {
					text = $(this).text();
					comentario = $('#external-payment-comments-comentario').val();
					if(comentario == '' || comentario == null || comentario == undefined) { swal({ type: "warning", title: "Datos insuficientes", text: "Debe especificar el motivo de la acción", timer: 4000 }); }
					else {
						data = {comentario: comentario, status: (text=='Invalidar'? 3: 1)};
						id = $('#external-payment-comments-id').val();
						$.ajax({ url: '<?= URL_API ?>venta_pago/edit/'+id, type: 'PUT', async: false, dataType: 'json', data: data, success: 
							function(data) {
								$('#frm-external-payment-comments').modal('hide');
								external_payment_getPagos();

								swal({ type: "success", title: "¡Listo!", text: "Se "+(data.status==3? 'invalidó': 'validó')+" el pago", timer: 4000 });
							}
						});
					}
				});

				$('#frm-external-payment-comments').on('shown.bs.modal', function() { $.get('<?= URL_API ?>venta_pago/get/'+$('#external-payment-comments-id').val(), function(resp) { $('#external-payment-comments-comentario').val(resp.result.comentario); }, 'json'); });
				$('#frm-external-payment-comments').on('hidden.bs.modal', function () { 
					$('#external-payment-comments-id').val(undefined);
					$('#external-payment-comments-comentario').val(undefined);
					$('#frm-external-sale').modal('show');
				});

				$('#external-sale-btnSave').click(function() { $('.invalid-tooltip').remove();
					if($(this).text() == 'Siguiente') {
						if($('#external-sale-id').val() == '') {
							data = {};
							$.each($('.data-external-sale'), function(index, elem) {
								ide = $(elem).attr('id').replace('external-sale-','');
								data[ide] = $.trim($(elem).val());
							});
		
							data.detalles = [];
							$.each($('#tbl-external-sale-prods tbody tr:not(.table-success, .imei)'), function(index, element) { element = $(element);
								producto_id = element.attr('data-id');
								cantidad = element.find('td:eq(1)').text();
								costo = element.find('td:eq(2)').text();
								importe = element.find('td:eq(3)').text();
								tipo = element.attr('data-tipo');
								detalles = { producto_id:producto_id, origen_tipo: 1, cantidad: cantidad, costo:costo, importe:importe, tipo:tipo, };
								if($(element).next().hasClass('imei')) { detalles.arrImei = $.trim($(element).next().find('textarea').val()).split('\n').filter(imei => $.trim(imei).length>0); }

								if(['servicio', 'paquete'].includes(tipo)) {
									detalles.origen_tipo = 2;
									detalles.productos = [];
									$.each(element.next('.servicio-info').find('tr[data-tipo="producto"]'), function(index, producto) { producto = $(producto);
										detalles.productos.push({
											producto_id: producto.attr('data-id'),
											cantidad: producto.find('td:eq(1)').text(),
											costo: producto.find('td:eq(2)').text(),
											importe: producto.find('td:eq(3)').text(),
										});
									});
								}

								data.detalles.push(detalles);
							});
		
							$errLabel = $('<div class="invalid-tooltip"></div>');
							if(data.folio == '') {
								$errLabel.html('Debe ingresar el folio');
								$('#external-sale-folio').after($errLabel).focus();
								$errLabel.show();
							} else if(data.detalles.length == 0) {
								$errLabel.html('Debe agregar productos a la venta');
								$('#tbl-external-sale-prods').after($errLabel);
								$errLabel.show();
							}else if(data.empleado_id == 0) {
								$errLabel.html('Debe seleccionar el vendedor');
								$('#external-sale-empleado_id').after($errLabel);
								$errLabel.show();
							} else {
								if(data.id != undefined) { delete data.id; }
								// < ?php // if(in_array(MOD_CLIENTE_ADD, $permisos)) : ?>
								// data.facturar = $('#chkFact').is(':checked') ? 1 : 0;
								// < ?php // else: ?>
								// data.facturar = 0;
								// < ?php // endif; ?>
								blockPage();
								$.post('<?= URL_API ?>venta/add/', data, function(venta) {
									if(venta.response) { id_venta = venta.result;
										$('#external-sale-id').val(id_venta);
										// $('#external-sale-cliente_id').prop('disabled', true);
										// $('#btn-external-sale-add-cliente').addClass('hide');
										// $('#external-sale-sucursal_id').prop('disabled', true);
										// $('.tbl-external-servicio-prodDel, .tbl_external_sale_det_servicio_btnEditProducto, .tbl_external_sale_det_servicio_btnDelProducto, .tnl_external_sale_btnRegaloCancel, .tnl_external_sale_btnRegalo').addClass('hide');
										// $('#tbl-external-sale-prods tfoot tr').addClass('hide');
										// $('#external-sale-empleado_id').prop('disabled', true);
										// $('#external-sale-descuento').prop('readonly', true);
										// $('#external-sale-pagos-tab').click().trigger('click');
										// $('#frm-external-sale .modal-header').css('padding-bottom', 0);
										// $('#frm-external-sale .modal-header').find('.row').last().removeClass('hide');
										// $('#tbl-external-payment-comments tbody').empty().append($('<tr><td colspan="6">No se ha registrado ningún pago</td></tr>'));

										data = { venta_id: id_venta, fecha: moment().format('YYYY-MM-DD hh:mm:ss'), tipo_pago_id: <?= $_SESSION['pago_efectivo'] ?>, importe: data.total, status:  1 };
										$.post('<?= URL_API ?>venta_pago/add/', data, function(pago) {
											if(pago.response) {
												finalizarVenta(1);
											} else { swal({ type:"warning", title:"Oops!", text:pago.message, timer:4000 }); }
										}, 'json');
									} else { swal({ type:"warning", title:"Oops!", text:venta.message, timer:4000 }); }
									$.unblockUI();
								},'json');
							}
						} else { $('#external-sale-pagos-tab').click().trigger('click'); }
					} else if($(this).text() == 'Guardar') {
						pagos = [];
						totalPagos = 0;
						$.each($('#tbl-external-payment-comments tbody tr[data-status="1"]').find('td:eq(2)'), function(index, item) {
							totalPagos += parseFloat($(item).text());
						});
						if(parseFloat($('#external-sale-total').val()) == totalPagos) {
							finalizarVenta(1);
						} else {
							$.get('<?= URL_API ?>cliente/get/'+$('#external-sale-cliente_id').val(), function(resp) {
								if(resp.result.tiene_credito == '1') { finalizarVenta(0); }
								else { swal({ type: "warning", title: "Oops!", text: 'Aún no completas la totalidad del pago requerido', html: true }); }
							})
						}
					}
				});

				function finalizarVenta(pagado) {
					$.post('<?= URL_API ?>venta/finalizar/'+$('#external-sale-id').val(), {pagado: pagado}, function(resp) {
						if(resp.response) {
							$('#external-sale-tab').click();
							$('#frm-external-sale').modal('hide');
							// getItems(0, $('#cont').val());
							swal({ type: "success", title: "¡Listo!", text: "Se guardó la venta correctamente.", timer: 4000 });
							window.open('<?= URL_API ?>venta/printTicket/'+$('#external-sale-id').val());
						}
					}, 'json');
				}

				$('#external-sale-cliente_id').change(function() {
					$.get('<?= URL_API ?>cliente/get/'+$('#external-sale-cliente_id option:selected').val(), function(resp) {
						if($('#external-sale-id').val() == undefined) {
							$('#external-sale-descuento').val(resp.result.descuento)
						}
					}, 'json');
				});
			
				<?php if(in_array(MOD_FACTURAR, $permisos)) : ?>
					$('#external-sale-cliente_id').change(function() {
						$('#chkFact').prop('checked', false);
						$('.invalid-tooltip').remove();
					});

					$('#chkFact').change(function(event) {
						if($(this).is(':checked')) {
							$('.invalid-tooltip').remove();
							blockPage();
							$.get('<?= URL_API ?>cliente/get/'+$('#external-sale-cliente_id').val(), function(data) {
								rfcReg = new RegExp('^[A-Z&Ñ]{3,4}[0-9]{2}(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])[A-Z0-9]{2}[0-9A]$');
								rfc = data.result.rfc;
								//$errLabel = $('<div class="invalid-tooltip"></div>');
								if(!rfcReg.test(rfc)) {
									/*$errLabel.html('El cliente no cuenta con un RFC válido');
									$('#chkFact').after($errLabel);
									$errLabel.show();
									setTimeout(function() { $errLabel.remove() }, 3000);*/
									$('#chkFact').prop('checked', false);
									swal({
										type: "error",
										title: "Oops!",
										text: 'El cliente no tiene un RFC válido.<br><small>Debe modificar los datos en el catálogo de <a href="<?= URL_ROOT ?>/clientes" title="Clientes" target="_blank">clientes</a></small>',
										html: true,
										timer: 4000
									});
								}
								if(data.timbres == 0) {
									$('#chkFact').prop('checked', false);
									$('#chkFact').prop('disabled', true);
									$('#chkFact').parents('.col-sm-4').find('small.text-muted').html('No cuenta con folios para facturar');
								}else{
									$('#chkFact').parents('.col-sm-4').find('small.text-muted').html(data.timbres+' folios disponibles');
								}
								$.unblockUI();
							},'json');
						}
					});
				<?php endif; ?>
			<?php endif; ?>

			<?php if(in_array(MOD_PAGO_ADD, $permisos)): ?>
				$('#btnAddPagoVenta').click(function() {
					$.get('<?= URL_API ?>venta/get/'+$('#external-sale-id').val(), function(venta) {
						total = parseFloat(venta.result.total);
						pagado = parseFloat(venta.pagado);
						$('#external-payment-cantidad').val(total<=pagado? 0: total-pagado);
						$('#external-payment-tipo_pago_id option[value="<?= $_SESSION['tipo_pago'] ?>"]').prop('selected', true);
						$('#btnSaveSub').addClass('add');
						$('#frm-external-payment').modal('show');
						$('#frm-external-sale').modal('hide');
					}, 'json');
				});

				$('#frm-external-payment').on('shown.bs.modal', function() {  });
				$('#frm-external-payment').on('hidden.bs.modal', function() { 
					$(this).find('input').val('');
					$('#frm-external-sale').modal('show'); 
					$('#external-sale-btnSave').addClass('update'); 
					$('#btnSaveSub').removeClass('add').removeClass('update'); 
					
					$(this).find('.commprobante').addClass('hide');
					$('#external-payment-cantidad').val(null);
					$('#external-payment-tipo_pago_id').val('01');
					$('#btn-comprobante').addClass('hide');
					$('#external-payment-comprobante').removeAttr('src');
					$(this).find('.comprobante').addClass('hide');
				});
			<?php endif; ?>

			$("#external-payment-cantidad").inputmask({ alias: "numeric", groupSeparator: ',', digits: 2, digitsOptional: false, placeholder: '0' });
			$('#external-payment-cantidad').parents('form').submit(function(e) { return false; });

			$('#external-payment-tipo_pago_id').change(function() {
				btnComprobante = $('#btn-comprobante');
				if(!$(this).find('option:selected').data('comprobante')) {
					btnComprobante.addClass('hide');
					$('#external-payment-comprobante').removeAttr('src');
					$('#frm-external-payment .comprobante').addClass('hide');
				} else {
					btnComprobante.removeClass('hide');
				}
			});
			
			$('#btn-comprobante').click(function() {
				$('#external-payment-file').click();
			});

			$('#external-payment-file').change(function() {
				if(this.files && this.files[0]) {
					var reader = new FileReader();

					reader.onload = function(e) {
						$('#external-payment-comprobante').attr('src', e.target.result);
					}
					
					reader.readAsDataURL(this.files[0]);
					$('#frm-external-payment .comprobante').removeClass('hide');
				}
			});

			$('#external-payment-btnSave').click(function() {
				importe = $('#external-payment-cantidad').val();
				image = $('#external-payment-comprobante').attr('src');
				tipo_pago_id = $('#external-payment-tipo_pago_id').val();

				if(importe == '' || !parseFloat(importe)>0) { swal({ type: "warning", title: "Datos insuficientes", text: "Debe ingresar la cantidad pagada",    timer: 4000 }); }
				else if(parseFloat(importe) > parseFloat($('#external-payment-sale-total').val())) { swal({ type: "warning", title: "Cantidad invalida", text: "El importe no puede ser mayor que la cantidad restante", timer: 4000 }); }
				else if($('#external-payment-tipo_pago_id option:selected').data('comprobante')==1 && (image==null || image==undefined || image=='#')) { swal({ type: "warning", title: "Datos insuficientes", text: "Debe ingresar el comprobante de pago", timer: 4000 }); }
				else {
					date = moment().format('YYYYY-MM-DD hh:mm:ss');
					data = new FormData();
					data.append('venta_id', $('#external-sale-id').val());
					data.append('fecha', date);
					data.append('tipo_pago_id', tipo_pago_id);
					data.append('importe', importe);
					data.append('status', $('#external-payment-tipo_pago_id option:selected').data('automatico') == '0'? -1: 1);
					if($('#external-payment-tipo_pago_id option:selected').data('comprobante') == '1') { data.append('comprobante', $('#external-payment-file')[0].files[0]); }
					$.ajax({ url: '<?= URL_API ?>venta_pago/add/', type: 'POST', data: data, contentType: false, processData: false, success: 
						function(resp) {
							if($('#external-payment-tipo_pago_id option:selected').data('automatico') == 1) {
								swal({ type: "success", title: "¡Listo!", text: "Pago registrado con exito", timer: 4000 });
								$('#frm-external-payment').modal('hide');
								external_payment_getPagos();
							} else {
								data = { url: '<?= URL_API ?>ventas', titulo: 'Pago Venta Folio '+$('#external-payment-sale-folio').val(), cantidad: 1, external_reference: resp.result, precio: $('#external-payment-cantidad').val() };
								$.ajax({ url: "<?= URL_API ?>pago/mercadopago", type: 'POST', data: data, dataType: 'json', async: false, success: function(callback) { location.href = callback.result; } });
							}
						}
					});
				}
			});

			$.get('<?= URL_API ?>tipo_pago/getAll/', function(tipos) {
				$('#external-payment-tipo_pago_id').empty();
				$.each(tipos.result, function(idx, item) { $('#external-payment-tipo_pago_id').append('<option value="'+item.id+'" data-comprobante="'+item.tiene_comprobante+'" data-automatico="'+item.es_automatico+'">'+item.nombre+'</option>'); });
			}, 'json');

			$("#external-sale-descuento").inputmask({ alias: "numeric", groupSeparator: ',', digits: 0, digitsOptional: false, mask: 99 });
			$('#external-sale-descuento').change(function() {
				ids = [];
				$.each($('#tbl-external-sale-prods tbody tr'), function(index, item) { ids.push($(item).data('id')+'-'+$(item).find('td:eq(1)').text()) });
				if($('#external-sale-id').val()==undefined || $('#external-sale-id').val()==0) {
					$.post('<?= URL_API ?>producto/maxDescuento/', {productos: ids.join(',')}, function(resp) {
						if(resp.result < $('#external-sale-descuento').val()) {
							$('#external-sale-descuento').val(resp.result);
	
							$errLabel = $('<div class="invalid-tooltip"></div>');
							$errLabel.html('El descuento máximo permitido es de '+resp.result+'%');
							$('#external-sale-descuento').parents('.form-group').after($errLabel).focus();
							$errLabel.show();	
	
							setTimeout(function () { $errLabel.hide() }, 3500);
						}
	
						subtotal = parseFloat($('#external-sale-subtotal').val());
						iva = parseFloat($('#external-sale-iva').val());
						descuento = parseInt($('#external-sale-descuento').val());
						total = (subtotal + iva) * (1 - (descuento / 100));
						$('#external-sale-total').val(total.toFixed(2));
					});
				}
			});
		});
	// }
	});
</script>