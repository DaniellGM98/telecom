					$("#external-sale-det-servicio-prod-cantidad, #external-sale-det-servicio-prod-costo").keyup(function(event) { if(event.keyCode == 13) external_sale_det_servicio_editProducto(); });
					$('#tbl-external-sale-prods').on('click', '.tbl_external_sale_det_servicio_btnSaveProducto', function() { external_sale_det_servicio_editProducto(); });
					function external_sale_det_servicio_editProducto() {
						clone = $('.clone');
						trPrev = clone.prev('tr[data-id="'+clone.data('id')+'"][data-tipo="producto"].hide');
						id = parseInt($('#external-sale-det-servicio-prod-id').val());				if(isNaN(id)) id = 0;
						cant = parseInt($('#external-sale-det-servicio-prod-cantidad').val());		if(isNaN(cant)) cant = 0;

						if(cant == 0) {
							swal({type: "warning", title: "Debe ingresar la cantidad", timer: 4000});
							$('#external-sale-det-servicio-prod-cantidad').focus();
						} else {
							if(!extermal_sale_det_servicio_prodExists(id)) {
								cantidad = 0;
								$.each($('#tbl-external-sale-prods tr[data-id="'+id+'"][data-tipo="producto"]:not(.hide)'), function(index, item) { 
									times = 1;
									cant = parseInt($.trim($(item).find('td:eq(1)').text()));
									if($(item).parents('.servicio-info').length > 0) { times = parseInt($.trim($(item).parents('.servicio-info').prev('tr').find('td:eq(1)').text())); }
									if(isNaN(cant)) { cant = parseInt($.trim($('#external-sale-det-servicio-prod-cantidad').val())); }
									cantidad += cant * times;
								});
								$.get('<?= URL_API ?>prod_kardex/getStockSuc/'+$('#external-sale-sucursal_id').val()+'/'+id, function(prod_kardex) {
									if(cant > parseInt(prod_kardex.result.final)) { swal({ type:"warning", title:"Stock insuficiente", text:"Solo existen "+prod_kardex.result.final+" productos en stock", html:true, timer:4000 }); }
									else if(cantidad > parseInt(prod_kardex.result.final)) { swal({ type:"warning", title:"Stock insuficiente", text:"Solo existen "+prod_kardex.result.final+" productos en stock<br />Revisa la información de tus servicios/paquetes", html:true, timer:4000 }); }
									else {
										if($('#tbl-external-sale-det-servicio-busProdServicio').length != 0) {
											trPrev.attr('data-id', $('#external-sale-det-servicio-prod-id').val());
											trPrev.find('td:eq(0)').html('<small>'+$('#tbl-external-sale-det-servicio-busProdServicio').val()+'</small>');
											trPrev.find('td:eq(1)').html('<small>'+$('#external-sale-det-servicio-prod-cantidad').val()+'</small>');
											trPrev.find('td:eq(2)').html('<small>'+$('#external-sale-det-servicio-prod-costo').val()+'</small>');
											trPrev.find('td:eq(3)').html('<small>'+$('#external-sale-det-servicio-prod-importe').val()+'</small>');
				
											trPrev.removeClass('hide');
											clone.remove();
		
											total = 0;
											$.each(trPrev.closest('tbody').find('tr'), function(index, item) { 
												total += parseFloat($.trim($(item).find('td:eq(3)').text())); 
											});
		
											idServicio = trPrev.data('servicio');
											$.get('<?= URL_API ?>servicio/get/'+idServicio, function(servicio) {
												if(servicio.response) {
													manoDeObra = parseFloat(servicio.result.mano_obra);
													servContainer = trPrev.parents('.servicio-info').prev('tr[data-id="'+idServicio+'"]');
													servContainer.find('td:eq(2)').html((total + manoDeObra).toFixed(2));
													servContainer.find('td:eq(3)').html((parseInt($.trim(servContainer.find('td:eq(1)').text())) * (total + manoDeObra)).toFixed(2));
		
													external_sale_calcTotal();
													$('.stock-insufficient').removeClass('stock-insufficient');
												}
											}, 'json');
										}
									}
								}, 'json');
							}
						}
					}

					$('#tbl-external-sale-prods').on('click', '.tbl_external_sale_det_servicio_btnCancelEditProducto', function() {
						if($('#tbl-external-sale-prods').find('.stock-insufficient').length != 0) { $(this).prev('.tbl_external_sale_det_servicio_btnSaveProducto').click(); }
						else {
							tr = $(this).closest('tr');
							id = tr.data('id');
							swal({ title: "Cancelar Modificación", text: "Esta acción es irreversible,<br />Se perderán todas las modificaciones hechas al producto<br />¿Desea Continuar?. \n", type: "warning", html: true, showCancelButton: true, cancelButtonText: "No", confirmButtonColor: "#DD6B55", confirmButtonText: "Si, cancelar", closeOnConfirm: true }, 
								function() {
									$('.clone').prev('tr[data-id="'+id+'"][data-tipo="producto"]').removeClass('hide');
									$('.clone').remove();
								}
							);
						}
					});
				});

