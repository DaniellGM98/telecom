						queryTokenizer: Bloodhound.tokenizers.whitespace,
						remote: {
							url: '<?= URL_API ?>producto/find/%QUERY',
							wildcard: '%QUERY'
						}
					});

					$('#tbl-external-sale-det-servicio-busProdServicio').typeahead({ hint: true, highlight: true, minLength: 3 }, { limit: 60, display: 'producto', source: fndOnlyProds });
					$('#tbl-external-sale-det-servicio-busProdServicio').change(function() { $('.invalid-tooltip').remove(); $('#frm-external-sale small.text-danger').html('');
						if($.trim($(this).val()) == '')
							$('#external-sale-det-servicio-prod-id').val(0);
