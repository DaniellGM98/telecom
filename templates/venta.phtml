					$('#tbl-external-sale-det-servicio-busProdServicio').bind('typeahead:select', function(ev, suggestion) { $('.invalid-tooltip').remove(); $('#frm-external-sale small.text-danger').html('');
						$('#external-sale-det-servicio-prod-id').val(suggestion.id);
						if(!extermal_sale_det_servicio_prodExists(suggestion.id)) {
