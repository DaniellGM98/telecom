				function tbl_external_sale_eliminarArticulo(articulo) {
					id = articulo.attr('data-id');
					$('#tbl-external-sale-prods tbody tr[data-id="'+id+'"]').remove();

					external_sale_calcTotal();
					$('#external-sale-prod-search').focus();
					if($('#tbl-external-sale-prods tbody tr').length == 0) { $('#external-sale-descuento').attr('readonly', 'readonly'); }
					$('#external-sale-descuento').trigger('change');
				}

				function external_sale_calcTotal() {
					tot = 0;
					$.each($('#tbl-external-sale-prods tbody .importe'), function(index, elem) {
						imp = parseFloat($.trim($(elem).text().replace('$', '')));
						tot += imp;
					});
					// sub = tot / 1.16;
					sub = tot;
					iva = sub * parseInt('<?= $_SESSION['iva'] ?>') / 100;
					tot += iva;
					$('#external-sale-subtotal').val(sub.toFixed(2));
					$('#external-sale-iva').val(iva.toFixed(2));
					$('#external-sale-total').val(tot.toFixed(2));
				}

