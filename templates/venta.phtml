					clone.find('td:eq(1)').html('<input type="text" class="form-control form-control-sm text-right" id="external-sale-det-servicio-prod-cantidad" placeholder="cantidad" value="'+cantidad+'">');
					clone.find('td:eq(2)').html('<div class="input-group"><select class="form-control form-control-sm col-sm-6" id="external-sale-det-servicio-prod-listap"></select><input type="text" class="form-control form-control-sm col-sm-6 text-right" id="external-sale-det-servicio-prod-costo" placeholder="0.00" inputmode="numeric" maxlength="10" readonly value="'+precio+'"></div>');
					clone.find('td:eq(3)').html('<input type="text" class="form-control form-control-sm text-right" id="external-sale-det-servicio-prod-importe" placeholder="0.00" inputmode="numeric" maxlength="10" readonly value="'+importe+'">');
					clone.find('td:eq(4)').css('min-width', '75px');
