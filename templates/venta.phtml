					$('#tbl-external-sale-det-servicio-busProdServicio').keyup(function(event) { if(event.keyCode == 8 || event.keyCode == 46) { $('#external-sale-det-servicio-prod-id').val(0); } });

					function extermal_sale_det_servicio_prodExists(prod) {
						if($('#tbl-external-sale-prods .clone').closest('tbody').find('tr[data-id="'+prod+'"][data-tipo="producto"]:not(.hide, .clone)').length > 0) {
							$errLabel = $('<div class="invalid-tooltip">Ya existe el producto</div>');
							$('#frm-external-sale small.text-danger').html('Ya existe el producto');
							$('#tbl-external-sale-det-servicio-busProdServicio').after($errLabel).select().focus();
							$errLabel.show();
							return true;
						}
						return false;
					}

					$('#external-sale-det-servicio-prod-listap').change(function() { $('#external-sale-det-servicio-prod-costo').val($(this).val()).trigger('change'); });
					$("#external-sale-det-servicio-prod-cantidad").inputmask({ alias: "numeric", digits: 0});
					$("#external-sale-det-servicio-prod-costo").inputmask({ alias: "numeric", groupSeparator: ',', digits: 2, digitsOptional: false, placeholder: '0' });
					$("#external-sale-det-servicio-prod-cantidad, #external-sale-det-servicio-prod-costo").change(function() { 
						cant = parseInt($('#external-sale-det-servicio-prod-cantidad').val());		if(isNaN(cant)) cant = 0;
						costo = parseFloat($('#external-sale-det-servicio-prod-costo').val());		if(isNaN(costo)) costo = 0;
						importe = cant * costo;
						
						$('#external-sale-det-servicio-prod-importe').val(importe.toFixed(2));
