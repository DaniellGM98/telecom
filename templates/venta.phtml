						data.telefono = data.telefono.replace('(','').replace(')','').replace(' ','').replace('-','').replace(/_/g, '');
						data.uso_cfdi = $('#external-client-uso_cfdi').val();
						rfcReg = new RegExp('^[A-Z&Ñ]{3,4}[0-9]{2}(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])[A-Z0-9]{2}[0-9A]$');

						$errLabel = $('<div class="invalid-tooltip"></div>');
						if(data.nombre == '') {
							$errLabel.html('Debe ingresar el nombre');
							$('#external-client-nombre').after($errLabel);
							$errLabel.show();
