			<?php if(in_array(MOD_ACTION_ADD, $permisos)) : ?>
			$('#btnSave').click(function() {
				$('.invalid-tooltip').remove();
				id = parseInt($('#item-id').val());
				
				data = {folio: $.trim($('#item-folio').val()), 
						subtotal: $('#item-total').val(), 
						total: $('#item-total').val(), 
						proveedor_id: $('#item-proveedor_id').val(), 
						sucursal_id: parseInt($('#item-sucursal_id').val())};

				data.detalles = [];
				preciotbl = '';
				$.each($('#tbl-prods tbody tr:not(.imei)'), function(index, elem) {
					prodtd = $(elem).find('td:eq(0)').text();
					cat = $(elem).find('td:eq(0)').data('cat');
					/*sku = prodtd.substring(1,prodtd.indexOf(']'));
					//prod = prodtd.substring(sku.length+2);
					prod = prodtd;
					sku = sku.replace('[','').replace(']','');
					det = {producto_id: $(elem).data('id'), cantidad: $(elem).find('td:eq(1)').text(), costo: $(elem).find('td:eq(2)').text(), importe: $(elem).find('td:eq(3)').text(), nombre: prod, sku: sku, modelo: '', tamano: ''};*/
					det = {producto_id: $(elem).data('id'), cantidad: $(elem).find('td:eq(1)').text(), costo: $(elem).find('td:eq(2)').text(), importe: $(elem).find('td:eq(3)').text(), 
						nombre: prodtd, modelo: '', tamano: '', categoria: cat, marca: ''};
					if($(elem).next().hasClass('imei')) { det.arrImei = $.trim($(elem).next().find('textarea').val()).split(', '); }
					data.detalles.push(det);
				});

				$errLabel = $('<div class="invalid-tooltip"></div>');
				if(data.sucursal_id == 0) {
					$errLabel.html('Debe seleccionar la sucursal');
					$('#item-sucursal_id').after($errLabel).focus();
					$errLabel.show();
				}else if(data.folio == '') {
					$errLabel.html('Debe ingresar el folio');
					$('#item-folio').after($errLabel).focus();
					$errLabel.show();
				}else if(data.detalles.length == 0) {
					$errLabel.html('Debe agregar productos a la entrada');
					$('#tbl-prods').after($errLabel);
					$errLabel.show();
				}else{
					blockPage();
					$.post($apiUrl+'add/', data, 
						function(resp) {
							if(resp.response) {
								$.each(data.detalles, function(idDetalle, detalle) {
									if(detalle.arrImei != undefined) {
										$.each(detalle.arrImei, function(idImei, imei) {
											copia = Object.assign({}, detalle);
											copia.sku = imei;
											copia.cantidad = 1;
											delete copia.arrImei;
											data.detalles.push(copia);
										});
										
										data.detalles.splice(idDetalle, 1);
									} else {
										detalle.sku = 'N/A';
									}
								});
								data.id = resp.result;
								d = new Date();
								data.fecha = d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear();
								if([0, parseInt($('#item-sucursal_id').val())].includes(parseInt($('#busSuc').val()))) { addRow(data); }
								$('#frm-item').modal('hide');
								swal({
									type: "success",
									title: "¡Listo!",
									text: "Se guardaron los datos correctamente.",
									timer: 4000
								});
							}else{
								swal({
									type: "warning",
									title: "Oops!",
									text: resp.message,
									timer: 4000
								});
							}
							$.unblockUI();
					},'json');
				}
			});
			<?php endif; ?>

