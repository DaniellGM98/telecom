			function addProducto() {
				global = [];
				$.each($('tr.imei:visible'), function(){
					varriable = $(this).find('textarea').val().split(', ');
					$.each(varriable, function(index, item){
						global.push(item);
					}); 
				});
				$('#frm-item small.text-danger').html('');
				prod_id = $('#prod-id').val();
				prod_cat = $('#prod-id').data('cat');
				prod = $.trim($('#busProd').val());
				cant = $.trim($('#prod-cantidad').val());
				costo = $.trim($('#prod-costo').val());
				imp = $.trim($('#prod-importe').val());
				arrImeiLinea = $.trim($('#prod-imei').val()).split('\n');
				arrImei = [];

				$.each(arrImeiLinea, function(index, item) {
									if($.trim(item).length>0){
										arrImei.push($.trim(item));
									}
								});

				if(!prodExists(prod_id) && (prod.length == 0 || prod_id == 0)) {
				  	$('#frm-item small.text-danger').html('Debe elegir un producto de la lista');
				  	$('#busProd').focus();
					return;
				}else if(cant.length==0 && !$('#prod-cantidad').prop('readonly')) {
				  	$('#frm-item small.text-danger').html('Debe ingresar la cantidad');
				  	$('#prod-cantidad').focus();
					return;
				}else if(costo.length == 0) {
				  	$('#frm-item small.text-danger').html('Debe ingresar el costo');
				  	$('#prod-costo').focus();
					return;
				} else if($('tr#sku').is(':visible') && arrImei.length==0) {
					$('#frm-item small.text-danger').html('Debe proporcionar todos los '+$('#prod-imei').attr('placeholder')+' de los productos');
					$('#prod-imei').focus();
					return;
				}

				sucursal_id = parseInt($('#item-sucursal_id').val());
				data = {id: prod_id, nombre: prod, cantidad: cant, costo: costo, importe: imp, categoria: prod_cat};
				if(prod.length > 0 && (cant.length>0 || $('#prod-cantidad').prop('readonly')) && costo.length > 0 && imp.length > 0 && $('#prod-id').val() > 0) {
					if(!prodExists($('#prod-id').val())) {
						if($('#sku:visible').length>0) { errores = [];
							data.importe = data.costo;
							$('#prod-imei').val('');
							arrSku = []; agregar = true;
							blockPage();
							$.get('<?= URL_API ?>/prod_entrada_detalle/getListaSkuDisp/'+prod_id, function(disponibles) { disp = disponibles.skuDisponibles; 
								// ent = disponibles.entradas;
								$.each(arrImei, function(index, item) {
									if((disp.length==0 || !disp.includes(item)) && !arrSku.includes(item)) {
										// if(ent.length==0 || !ent.includes(item)) {
											arrSku.push(item);
										// } else { agregar = false; errores.push(item); }
									} else { agregar = false; errores.push(item); }
								});

								var sku_duplicate_add = [];
								$.each(arrSku, function (index, item) {
								  if ($.inArray(item, global) != -1) {
								    sku_duplicate_add.push(item);
								  }
								});
								
								// FILTRO QUITAR
								difference_add = arrSku.filter((x) => !sku_duplicate_add.includes(x));
								//global = global.concat(arrSku);
								global = global.concat(difference_add);
								
								// QUITAR DUPLICADOS
								Array.prototype.unique = (function (a) {
								  return function () {
								    return this.filter(a);
								  };
								})(function (a, b, c) {
								  return c.indexOf(a, b + 1) < 0;
								});
								
								// COMPARAR EN LA BASE
								var data_without_filter = JSON.stringify(Object.assign({}, difference_add));
								var difference;
								var sku_duplicate_database = [];
								if(difference_add.length > 0){
								$.ajax({
								  url: "<?= URL_API ?>/prod_entrada/getsku",
								  type: "POST",
								  dataType: "json",
								  contentType: "application/json; charset=utf-8",
								  data: data_without_filter,
								  success: function (datos) {
									if (datos != null && datos.length != 0) {
										$.each(datos, function (index, item) {
											if (difference_add.includes(item.sku)) {
											sku_duplicate_add.push(item.sku);
											}
										});
										$cadena = sku_duplicate_add.join("\n");
										if (datos.length != 0) {
											$("#frm-item small.text-danger").html(
											$categoria_sku +
												" REGISTRADOS PREVIAMENTE: \n" +
												sku_duplicate_add.join("<br>")
											);
										}
										// FILTRO QUITAR
										difference = arrImei.filter((x) => !sku_duplicate_add.includes(x));
										difference = difference.unique();
										$("#prod-imei").val(difference.join("\n") + "\n");
									} else if (datos.length == 0) {
										difference_add = difference_add.unique();
										$("#prod-imei").val(difference_add.join("\n") + "\n");
										if (agregar) {
											data.arrImei = difference_add;
											agregarProducto(data);
										} else {
											errores = errores.concat(sku_duplicate_add);
											$("#frm-item small.text-danger").html(
											$categoria_sku + " REGISTRADOS PREVIAMENTE: \n" + errores.join("<br>")
											);
										}
									}
									$.unblockUI();
								  },
								});
							}else{ $("#frm-item small.text-danger").html(
											$categoria_sku +
												" REGISTRADOS PREVIAMENTE: \n" +
												errores.join("<br>")
											);
									$.unblockUI();
										}
							}, 'json');
						} else { 
							agregarProducto(data);
						}
					}
				}
			}
			function agregarProducto(data) {
				if($('#btnSave').is(':visible')) {
					container = $('#tbl-prods tbody');
					tr = $('<tr data-id="'+data.id+'"></tr>').appendTo(container);
					tr.append('<td data-cat="'+data.categoria+'"><small class="producto">'+data.nombre+'</small></td>');
					tr.append('<td class="text-right"><small class="cantidad">'+(data.arrImei==undefined? data.cantidad: data.arrImei.length)+'</small></td>');
					tr.append('<td class="text-right"><small class="costo">'+data.costo+'</small></td>');
					tr.append('<td class="text-right importe"><small class="importe">'+(data.arrImei==undefined? data.importe: parseFloat(data.arrImei.length*parseFloat(data.importe)).toFixed(2))+'</small></td>');
					tr.append('<td><div class="pull-rigth"><button class="btn btn-sm btn-danger pull-right prodDel" type="button"><i class="fa fa-trash"></i></button></div></td>');
					if(data.arrImei != undefined) { container.append('<tr class="imei" data-id="'+data.id+'"><td colspan="5"><textarea disabled="disabled" class="form-control">'+data.arrImei.join(', ')+'</textarea></td></tr>'); }
					calcTotal();
					clearDataProd();
					$('#busProd').focus();
				} else {
					data = { prod_entrada_id: $('#item-id').val(), producto_id: $('#prod-id').val(), cantidad: $('#prod-cantidad').val(), costo: $('#prod-costo').val(), importe: $('#prod-importe').val() };
					if($('#prod-imei').is(':visible')) { data.arrSku = $('#prod-imei').val().split('\n').filter(imei => $.trim(imei).length > 0); }
					$.post('<?= URL_API ?>prod_entrada_detalle/add/', data, function(resp) {
						if(resp.response) {
							getItems(0,$('#cont').val());
							$('#frm-item').modal('hide');
							swal({ type:"success", title:"¡Listo!", text:"Se agregó el registro", timer:4000 });
						} else { swal({ type: "warning", title: "Oops!", text: resp.message, timer: 4000 }); }
					}, 'json');
				}
			}

			$('tbody').on('click', '.prodDel', function(event) {
				event.preventDefault();
				tr = $(this).parents('tr');
				id = tr.attr('data-id');
				if($('#btnSave').is(':visible')) {
