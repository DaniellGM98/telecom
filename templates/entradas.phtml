	<script type="text/javascript">
		$(function() {
			$apiUrl = '<?= URL_API ?>prod_entrada/';
			$categoria_id = 0;
			$categoria_sku = '';
			$('.input-daterange-datepicker').daterangepicker({
				buttonClasses: ['btn', 'btn-sm'],
				applyClass: 'btn-primary',
				cancelClass: 'btn-inverse',
				maxDate: '<?= date('d/m/Y') ?>',
				locale: $dateRangeLocale,
				ranges: $dateRanges,
				alwaysShowCalendars: true,
				autoApply: true
			}, function(start, end, label) {
				getItems(0,10);
			});

			$.get($apiUrl.replace('prod_entrada','sucursal')+'getAll/', function(data) {
				$.each(data.result, function(index, item) {
					$('#busSuc').append('<option value="'+item.id+'">'+item.nombre+'</option>');
				});
			},'json');

			/*$.get($apiUrl.replace('prod_entrada','sucursal')+'getAll/', function(data) {
				$.each(data.result, function(index, item) {
					$('#item-sucursal_id, #busSuc').append('<option value="'+item.id+'">'+item.nombre+'</option>');
				});
				if(data.result.length == 1) $('.sucursal').addClass('hide');

				$.get($apiUrl.replace('prod_entrada','proveedor')+'getAll/', function(data) {
					$.each(data.result, function(index, item) {
						$('#item-proveedor_id').append('<option value="'+item.id+'">'+item.nombre+'</option>');
					});
					if(data.result.length == 1) $('.proveedor').addClass('hide');
					//getItems(0,10); 

				},'json');
			},'json');*/

			function getItems(pag, lim) {
				$('#btnFolio').popover('hide');
				$('#tbl-items tbody').empty();
				bus ='';
				bus = $.trim($('#bus').val());
				if(bus == '') bus = 0;;
				suc = $('#busSuc').val();
				if(suc == -1){
					$('#tbl-items tbody').append('<tr><td colspan="8"><small>Seleccione la sucursal para ver las ventas del periodo</small></td></tr>');
					return false;
				}
				blockPage();
				prov = 0;//$('#lst-pre').val();
				var fechas = $('#fechas').data('daterangepicker');
				ini = fechas.startDate.format('YYYY-MM-DD');
				fin = fechas.endDate.format('YYYY-MM-DD');
				cat = $('#busCat').val();
				$.get($apiUrl+'getAll/'+ini+'/'+fin+'/'+pag+'/'+lim+'/'+suc+'/'+prov+'/'+bus+'/'+cat, function(resp) {
					$.unblockUI();
					total = 0;
					if(resp.total > 0) { 
						$.each(resp.result, function(index, item) {
							if(parseFloat(item.total) > 0) { addRow(item); total++; }
						});
					}else{
						$('#tbl-items tbody').append('<tr data-ent="0"><td colspan="9"><small>No existen productos con ese termino</small></td></tr>');
					}
					doPagination(total, lim, pag);
				});
			}

			function addRow(item) {
				$('#tbl-items tbody tr[data-ent="0"]').remove();
				tr = $('<tr data-ent="'+item.id+'"></tr>');
				if($('#tbl-items [data-id="'+item.id+'"]').length > 0) {
					tr = $('#tbl-items [data-id="'+item.id+'"]').parents('tr');
					tr.empty();
				}

				rspan = item.detalles.length;
				tr.append('<td rowspan="'+rspan+'"><small>'+item.fecha+'</small></td>');
				btnCancel = '';
				btnEdit = '';

				if(/*moment().format('DD/MM/YYYY') == item.fecha &&*/ <?= in_array(MOD_ACTION_EDIT, $permisos)? 'true': 'false' ?>) {
					btnEdit = '<a href="#" data-popup="tooltip" title="Editar" class="btnEdit pull-right"><i class="mdi mdi-pencil"></i></a>';
				}
				<?php if(in_array(MOD_ACTION_DEL, $permisos)) : ?>
					btnCancel = '<a href="#" data-popup="tooltip" title="Cancelar" class="btnDel pull-right"><i class="mdi mdi-close-circle" style="color:red;"></i></a>';
				<?php endif; ?>
				tr.append('<td rowspan="'+rspan+' "data-id="'+item.id+'"><small>'+item.folio+btnCancel+btnEdit+'</small></td>');
				suc = $('#busSuc option[value="'+item.sucursal_id+'"]').text();
				tr.append('<td rowspan="'+rspan+'"><small>'+suc+'</small></td>');
				$.each(item.detalles, function(index, det) {
					tr.append('<td class="text-center"><small>'+det.categoria+'</small></td>');
					tr.append('<td><small>'+det.marca+' '+det.nombre+' '+(det.tamano==null? '': det.tamano)+(det.sku!=null? ' - <strong>'+det.sku+'</strong>': '')+'</small></td>');
					// tr.append('<td><small>'+det.sku+'</small></td>');
					tr.append('<td class="text-center"><small>'+det.cantidad+'</small></td>');
					tr.append('<td class="text-right"><small>$ '+det.costo+'</small></td>');
					tr.append('<td class="text-right"><small>$ '+det.importe+'</small></td>');
					
					$('#tbl-items tbody').append(tr);
					tr = $('<tr data-ent="'+item.id+'"></tr>');
				});
			}
		
			$('#bus').keyup(function(e) { if(e.keyCode == 13) { getItems(0, $('#cont').val()); } });
			$('#btn-bus').click(function(e) { getItems(0, $('#cont').val()); });
			$('#cont').change(function() { cont = $(this).val(); getItems(0,cont); });
			$('#busSuc').change(function() { getItems(0,$('#cont').val()); });
			$('#busCat').change(function() { getItems(0,$('#cont').val()); });

			$('#btnFolio').popover({
				placement: 'top',
				html:true,
				sanitize: false, 
				content:  '<div class="form"><div class="input-group"><input type="text" class="form-control form-control-sm" placeholder="Folio" id="buscafolioi"><div class="input-group-append"><button type="button" class="btn btn-secondary btn-sm" id="btn-busf"><i class="fa fa-search"></i></button></div></div></div>'
			}).on('click', function(e) {
				e.preventDefault();
				$('#buscafolioi').keyup(function(e) { if(e.keyCode == 13) { buscaFolio(); } });
				$('#btn-busf').click(function() { buscaFolio(); });
			});
			$('#btnFolio').on('shown.bs.popover', function () { $('#buscafolioi').val('').focus(); });

			function buscaFolio() {
				folio = $.trim($('#buscafolioi').val());
				if(folio != '') {
					$('#btnFolio').popover('hide');
					blockPage();
					$('#tbl-items tbody').empty();
					$.get($apiUrl+'buscaFolio/'+folio, function(resp) {
						$.unblockUI();
						if(resp.total > 0) {
							$.each(resp.result, function(index, item) {
								addRow(item);
							});
						}else{
							$('#tbl-items tbody').append('<tr><td colspan="7"><small>No existen entradas con ese folio</small></td></tr>');
						}
						doPagination(resp.total, 10, 0);
					});
				}
			}

			$('#frm-item').on('show.bs.modal', function() {
				$('#item-sucursal_id, #item-proveedor_id, #item-prod_categoria_id').empty();
				$.get('<?= URL_API ?>venta/getInfoVenta/', function(info) {
					$('#item-sucursal_id').empty().append('<option value="0">SELECCIONA</option>');
