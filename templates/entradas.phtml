					$errLabel.show();
				} else {
					blockPage();
					data.status = 1;
					$.post('<?= URL_API ?>proveedor/add/', data, function(resp) {
						if(resp.response) {
							data.id = resp.result;
							$('#proveedor-id').val(0);
							$('#frm-proveedor').modal('hide');
							swal({ type: "success", title: "¡Listo!", text: "Se guardaron los datos correctamente.", timer: 4000 });
