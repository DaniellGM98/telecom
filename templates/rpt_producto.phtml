					$('#filtro_semana').append('<option value="3">' + moment().subtract(1, 'months').add(2, 'weeks').startOf('isoWeek').format('DD') + ' - ' + moment().subtract(1, 'months').add(1, 'weeks').endOf('isoWeek').format('DD MMMM')+  '</option>');
					$('#filtro_semana').append('<option value="4">' + moment().subtract(1, 'months').add(3, 'weeks').startOf('isoWeek').format('DD') + ' - ' + moment().subtract(1, 'months').endOf('month').format('DD MMMM')+  '</option>');
					// MES ACTUAL
					$('#filtro_semana').append('<option value="5">' + moment().startOf('month').format('DD')                   + ' - ' + moment().add(0, 'weeks').endOf('isoWeek').format('DD MMMM')+  '</option>');
					$('#filtro_semana').append('<option value="6">' + moment().add(1, 'weeks').startOf('isoWeek').format('DD') + ' - ' + moment().add(1, 'weeks').endOf('isoWeek').format('DD MMMM')+  '</option>');
					$('#filtro_semana').append('<option value="7">' + moment().add(2, 'weeks').startOf('isoWeek').format('DD') + ' - ' + moment().add(1, 'weeks').endOf('isoWeek').format('DD MMMM')+  '</option>');
					$('#filtro_semana').append('<option value="8">' + moment().add(3, 'weeks').startOf('isoWeek').format('DD') + ' - ' + moment().endOf('month').format('DD MMMM')+  '</option>');
				}else if ($('#filtro_periodo').val() == 2) {
					$('#fechas').append('<input class="form-control input-daterange-datepicker" type="text" id="fechas" value="<?= date("d/m/Y",strtotime(date("01-m-Y"))) . ' - ' . date('d/m/Y') ?>" />');
					$('#fechas').show();
					$('#filtro_mensual').hide();
					$('#filtro_semana').hide();
				}
			});
			$('#filtro_periodo').trigger('change');
			getItems(0, 100, 1, 0); 
			function getItems(pag, lim, mensual , filtro1 ) {
				vend = $('#filtro_periodo').val();
				if(vend == 0 || vend == 1 || vend == 2){
					$('#tbl-items tbody').empty();
					blockPage();
					suc = $('#busSuc').val();
					cat = $('#busCat').val();
					// (mensual == '') ? mensual = 0 : mensual = $('#filtro_mensual').val();
					mensual = $('#filtro_mensual').val();
					// filtro1 = $('#filtro_semana').val();
					(filtro1 == '' || filtro1 == null) ? filtro1 = 0 : filtro1 = $('#filtro_semana').val();
					var fechas = $('#fechas').data('daterangepicker');
					
					if(vend == 0){
						switch (mensual) {
							case '1':
									ini = moment().startOf('month').set({'month': 0}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 0}).format('YYYY-MM-DD');
								break;

								case '2':
									ini = moment().startOf('month').set({'month': 1}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 1}).format('YYYY-MM-DD');
								break;

								case '3':
									ini = moment().startOf('month').set({'month': 2}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 2}).format('YYYY-MM-DD');
								break;
									
								case '4':
									ini = moment().startOf('month').set({'month': 3}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 3}).format('YYYY-MM-DD');
								break;
									
								case '5':
									ini = moment().startOf('month').set({'month': 4}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 4}).format('YYYY-MM-DD');
								break;

								case '6':
									ini = moment().startOf('month').set({'month': 5}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 5}).format('YYYY-MM-DD');
								break;

								case '7':
									ini = moment().startOf('month').set({'month': 6}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 6}).format('YYYY-MM-DD');
								break;

								case '8':
									ini = moment().startOf('month').set({'month': 7}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 7}).format('YYYY-MM-DD');
								break;

								case '9':
									ini = moment().startOf('month').set({'month': 8}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 8}).format('YYYY-MM-DD');
								break;

								case '10':
									ini = moment().startOf('month').set({'month': 9}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 9}).format('YYYY-MM-DD');
								break;
								
								case '11':
									ini = moment().startOf('month').set({'month': 10}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 10}).format('YYYY-MM-DD');
								break;

								case '12':
									ini = moment().startOf('month').set({'month': 11}).format('YYYY-MM-DD');
									fin = moment().endOf('month').set({'month': 11}).format('YYYY-MM-DD');
								break;
								
						}
					} else if (vend == 1) {
						switch (filtro1) {
								case '1':
									ini = moment().subtract(1, 'months').startOf('month').format('YYYY-MM-DD');
									fin = moment().subtract(1, 'months').add(0, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;

								case '2':
									ini = moment().subtract(1, 'months').add(1, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().subtract(1, 'months').add(1, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;

								case '3':
									ini = moment().subtract(1, 'months').add(2, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().subtract(1, 'months').add(2, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;
									
								case '4':
									ini = moment().subtract(1, 'months').add(3, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().subtract(1, 'months').endOf('month').format('YYYY-MM-DD');
								break;

								case '5':
									ini = moment().startOf('month').format('YYYY-MM-DD');
									fin = moment().add(0, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;

								case '6':
									ini = moment().add(1, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().add(1, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;

								case '7':
									ini = moment().add(2, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().add(2, 'weeks').endOf('isoWeek').format('YYYY-MM-DD');
								break;
									
								case '8':
									ini = moment().add(3, 'weeks').startOf('isoWeek').format('YYYY-MM-DD');
									fin = moment().endOf('month').format('YYYY-MM-DD');
								break;
						}
					}else if(vend == 2){
						ini = fechas.startDate.format('YYYY-MM-DD');
						fin = fechas.endDate.format('YYYY-MM-DD');
					}
					$.get($apiUrl+'getVentasByProducto/'+ini+'/'+fin+'/'+suc+'/'+cat, function(resp) {
						if(resp.result.length > 0) {
							if ( $.fn.dataTable.isDataTable( '#tbl-items' ) ) {
								$('#tbl-items').DataTable().destroy();
							}
							$('#tbl-items tbody').empty();
							container = $('<div class="form-inline"></div>');
							prods = 0;
							
							$.each(resp.result, function(index, item) {

								addRow(item);
								// $.each(item, function (index, det) { 
									prods+=parseInt(item.total_cantidad); 
								// });
							});

							function getTrElement(tblName, tr) {
								container1 = $('<div></div>');
								trInfo = $('#'+tblName).DataTable().row(tr).data();
								$.each(trInfo, function(index, trInfoRow) {
									container1.append(trInfoRow);
								});
							
								return container1;
							}
						
							function calcTot(tbl){
								tot = 0;
								$.each($('#'+tbl).DataTable().rows({filter: 'applied'})[0], function(index, tr) {
									precio = getTrElement(tbl, tr).text().split('$')[1];
									imp = parseFloat(precio);	
									tot += imp;
								});
								return tot;
							}

							function calcTot1(tbl){
								tot1 = 0;
								$.each($('#'+tbl).DataTable().rows({filter: 'applied'})[0], function(index, tr) {
									cantidad = getTrElement(tbl, tr).html().split('</small>')[1].split('$')[0];
									imp = parseFloat(cantidad);	
									tot1 += imp;
								});
								return tot1;
							}
							$('#tbl-items tfoot th:eq(0) small').html(prods+' productos en '+resp.result.length+' ventas registradas en el periodo');
							$('#tbl-items tfoot th:eq(2)').html('$ '+resp.total);

							order = [1, 'desc'];

							searchContainer = $('<div class="input-group"></div>').appendTo(container);
							searchContainer.append('<div class="input-group-prepend"><div class="input-group-text"><span class="fa fa-filter"></span></div></div>');
							search = $('<input type="text" id="bus" placeholder="Buscar" class="form-control">').appendTo(searchContainer);
							searchContainer.append('<input type="hidden" id="producto-id" value="0">');
							search.keyup(function(e) { $("#tbl-items"+"_filter label input").val($.trim($(this).val())).trigger('keyup'); });
							search.on("search", function(evt) { $("#tbl-items"+"_filter label input").val(undefined).trigger('keyup'); });
							
							buttonsContainer = $('<div class="buttons"></div>').appendTo(container);
							buttonPDF = $('<button type="button" class="btn ml-2 btn-sm btn-inline-block" title="Exportar a PDF"><span class="mdi mdi-file-pdf-box fa-2x" style="color: red;"></span></button>').appendTo(buttonsContainer);
							buttonExcel = $('<button type="button" class="btn btn-sm btn-inline-block" title="Exportar a Excel"><span class="mdi mdi-file-excel-box fa-2x" style="color: green;"></span></button>').appendTo(buttonsContainer);
							$('[data-toggle="tooltip"]').tooltip();

							$('#tbl-items').DataTable({
								"paging":   false,
								// "searching": false,
								'dom': 'Bl<"#toolbar-tbl-items">frtip',
								"info":     false,
								'order': order,
								'fnDrawCallback': function() {
								$('#totalTabla').html(new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(calcTot('tbl-items')));
								$('#totalTablaC').html('Totales:  ' + calcTot1('tbl-items'));
								},
								'buttons': [
									'excelHtml5',
									// 'pdfHtml5'
									{
										extend: 'pdfHtml5',
										title: 'Reporte de ventas por producto | Telecom',
										customize: function(doc) {
											// doc.pageOrientation = 'landscape',
											doc.pageMargins = [40, 10, 10, 10],
											doc.defaultStyle.fontSize = 10
										}
									}
								]
							});

							$('#toolbar-tbl-items').html(container).addClass('pull-right');
							$("#tbl-items"+"_filter label").hide();
							$('#tbl-items').parents('.table-responsive').css('overflow', 'visible');
							$.each($($('#tbl-items').DataTable().buttons()), function(index, item) { $(item.node).addClass('hide') });
							buttonPDF.click(function(e) { e.preventDefault(); $('#tbl-items').DataTable().buttons()[1].node.click() });
							buttonExcel.click(function(e) { e.preventDefault(); $('#tbl-items').DataTable().buttons()[0].node.click() });

						}else{
							$('#tbl-items tbody').append('<tr><td colspan="3"><small>No existen ventas para este producto en el periodo</small></td></tr>');
							$('#tbl-items tfoot th:eq(0) small').html('');
							$('#tbl-items tfoot th:eq(1)').html('');
							$('#tbl-items tfoot th:eq(2)').html('$ '+resp.total);
						}
						$.unblockUI();
					});
				}
			}

			function addRow(item) {
				tr = $('<tr data-ent="'+item.id+'"></tr>');
				if($('#tbl-items [data-id="'+item.id+'"]').length > 0) {
					tr = $('#tbl-items [data-id="'+item.id+'"]').parents('tr');
					tr.empty();
				}

				// rspan = item.detalles.length;
				// btnPrint = '';//'<a href="<?= URL_ROOT ?>/venta/print/'+item.id+'?dl=1" target="_blank" data-popup="tooltip" title="Imprimir" class="btnPrint"><i class="mdi mdi-printer"></i></a> ';

				// $.each(item, function(index, det) {
					item.sku = item.sku == null ? '' : item.sku;
					tr.append('<td><small>'+item.nombre+' '+item.modelo+'</small></td>');
					tr.append('<td class="text-center">'+item.total_cantidad+'</td>');
					tr.append('<td class="text-right">$ '+item.total+'</td>');

					$('#tbl-items tbody').append(tr);
					tr = $('<tr data-ent="'+item.id+'"></tr>');
				// });
			}
		
			$("#filtro_periodo, #busCat, #busSuc, #filtro_mensual, #filtro_semana").change(function () { getItems(0, $("#cont").val(), $('#filtro_mensual').val(), $('#filtro_semana').val()); });
		});
		
	</script>
