					  weekdaysMin: 'Do_Lu_Ma_Mi_Ju_Vi_Sa'.split('_')
					}
					);
					// MES ANTERIOR
					$('#filtro_semana').empty();
					$('#fechas').hide();
					$('#filtro_mensual').hide();
