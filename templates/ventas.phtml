							});

							$('#tbl-items-sub tbody').empty();
							if(venta.pagos.length > 0) {
								$.each(venta.pagos, function(index, item) {
									addRowPago(item);
								});
							} else {
								$('#tbl-items-sub tbody').append('<tr><td colspan="6">No se ha registrado ningún pago</td></tr>');
							}
						}
					}, 'json');
				});
			<?php endif; ?>

