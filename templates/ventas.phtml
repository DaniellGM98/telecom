				e.preventDefault();
				$('#buscafolioi').keyup(function(e) { if(e.keyCode == 13) { buscaFolio(); } });
				$('#btn-busf').click(function() { buscaFolio(); });
			});
			$('#btnFolio').on('shown.bs.popover', function () { $('#buscafolioi').val('').focus(); });

			function buscaFolio() {
				folio = $.trim($('#buscafolioi').val());
				if(folio != '') {
					$('#btnFolio').popover('hide');
					blockPage();
					$('#tbl-items tbody').empty();
					$('#tbl-items').parents('.card').find('.card-footer strong').html('$ 0.00');
					$.get($apiUrl+'buscaFolio/'+folio, function(resp) {
						$.unblockUI();
						if ( $.fn.dataTable.isDataTable( '#tbl-items' ) ) {
							$('#tbl-items').DataTable().destroy();
						}
						$('#tbl-items tbody').empty();
						if(resp.total > 0) {
							$.each(resp.result, function(index, item) {
								addRow(item);
							});
							$('#tbl-items').parents('.card').find('.card-footer strong').html('$ '+resp.suma);
						}else{
							//$('#tbl-items tbody').append('<tr><td colspan="8"><small>No existen ventas con ese folio</small></td></tr>');
						}
						doTable(resp.suma);
					});
