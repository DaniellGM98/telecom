				// cli = $('#item-cliente_id option[value="'+item.cliente_id+'"]').text();
				// row = $('<td rowspan="'+rspan+'"><small>'+cli+'</small></td>');
				//row =  $('<td class="hide" rowspan="'+rspan+'"><small>'+(item.cliente.nombre+' '+item.cliente.apellidos).toUpperCase()+'</small></td>');
				row =  $('<td class="hide" rowspan="'+rspan+'"><small></small></td>');
				<?php if(in_array(MOD_ACTION_PAGO_ADD, $permisos) || in_array(MOD_ACTION_PAGO_VALID, $permisos) || in_array(MOD_ACTION_PAGO_CANCEL, $permisos)) : ?>
