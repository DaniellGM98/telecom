			function getItems(pag, lim) {
				$('#btnFolio').popover('hide');
				suc = $('#busSuc').val();
				if(suc == -1){
					//$('#tbl-items tbody').empty().append('<tr><td colspan="8"><small>Seleccione la sucursal para ver las ventas del periodo</small></td></tr>');
					return false;
				}
				blockPage();
				var fechas = $('#fechas').data('daterangepicker');
				ini = fechas.startDate.format('YYYY-MM-DD');
				fin = fechas.endDate.format('YYYY-MM-DD');
				$('#tbl-items').parents('.card').find('.card-footer strong').html('$ 0.00');
				$.get($apiUrl+'getAll/'+ini+'/'+fin+'/'+pag+'/0/'+suc+'/0/0', function(resp) {
					$.unblockUI();
					if ( $.fn.dataTable.isDataTable( '#tbl-items' ) ) {
						$('#tbl-items').DataTable().destroy();
					}
					$('#tbl-items tbody').empty();
					if(resp.total > 0) {
						$.each(resp.result, function(index, item) {
							addRow(item);
						});
						$('#tbl-items').parents('.card').find('.card-footer strong').html('$ '+resp.suma);
					}else{
						//$('#tbl-items tbody').append('<tr data-ent="0"><td colspan="8"><small>No existen productos con ese termino</small></td></tr>');
					}
					doTable(resp.suma);
				});
			}
			
			function doTable(total){
				clase = 'btn btn-sm btn-secondary';
				title = '<h2>Sucursal <strong>'+$('#busSuc option:selected').text()+'</strong> Periodo '+$('#fechas').val()+'<h2>';
				footer = '<h2 class="text-right text-dark m-t-20">Total: <strong>$ '+total+'</strong></h2>';
				titleExp = 'Sucursal '+$('#busSuc option:selected').text()+' Periodo '+$('#fechas').val();
				footerExp = ' Total: $ '+total;
				$('#tbl-items').DataTable({
					dom: 'lBfrtip',
					buttons: [
						{ extend: 'print', className: clase, messageTop: title, messageBottom: footer, text: 'Imprimir' }, 
						{ extend: 'excel', className: clase, messageTop: titleExp, messageBottom: footerExp, autoFilter: true, }, 
						{ extend: 'pdf', className: clase, messageTop: titleExp+footerExp, download: 'open' }, 
					]
				});
			}

			function addRow(item) {
				$('#tbl-items tbody tr[data-ent="0"]').remove();
				tr = $('<tr data-ent="'+item.id+'"></tr>');
				if($('#tbl-items [data-id="'+item.id+'"]').length > 0) {
					tr = $('#tbl-items [data-id="'+item.id+'"]').parents('tr');
					tr.empty();
				}
				
				btnFact = '--';
				$.each(item.detalles, function(index, det) {
					row = $('<td data-id="'+item.id+'">'+item.folio+'</td>').appendTo(tr);
					actions = $('<div class="pull-right"></div>').appendTo(row);
					actions.append('<a href="#" data-popup="tooltip" title="Imprimir Ticket" class="btnPrintTicket"><i class="fa fa-ticket"></i></a>');
					<?php if(in_array(MOD_ACTION_DEL, $permisos)) : ?>
					actions.append(' | <a href="#" data-popup="tooltip" title="Cancelar" class="btnDel"><i class="mdi mdi-close-circle" style="color:red;"></i></a>');
					<?php endif; ?>
					tr.append('<td><small>'+item.fecha+' '+item.hora+'</small></td>');
					tr.append('<td><small>'+det.nombre+' '+det.modelo+' '+(det.tamano==null? '': det.tamano)+(det.sku!=''? ' - <strong>'+det.sku+'</strong>': '')+'</small></td>');
					tr.append('<td class="text-center">'+det.cantidad+'</td>');
					tr.append('<td class="text-right">'+det.costo+'</td>');
					tr.append('<td class="text-right">'+det.importe+'</td>');

					$('#tbl-items tbody').append(tr);
					tr = $('<tr data-ent="'+item.id+'"></tr>');
				});
			}

