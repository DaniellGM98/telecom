					labels = []; data = []; colors = []; hoverColors = [];
					$.each(resp.result, function(index, item) { labels.push(item.nombre!=''? item.nombre: 'recargas'); data.push(item.total); colors.push(getRandomRGB()); hoverColors.push(getRandomRGB()); });
					var chartSalesByCategoria = new Chart(context, { 
						type: 'pie',
						data: {
							labels: labels,
							datasets: [{
								data: data,
								backgroundColor: colors,
								hoverBackgroundColor: colors
							}] 
