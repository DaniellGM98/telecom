			function getItems(pag, lim) {
				blockPage();
				$('#btnFolio').popover('hide');
				$('#tbl-items tbody').empty();
				//bus ='';
				//bus = $.trim($('#bus').val());
				//if(bus == '') bus = 0;;
				//suc = $('#busSuc').val();
				vend = $('#busVend').val();
				suc = $('#busSuc').val();
				var fechas = $('#fechas').data('daterangepicker');
				ini = fechas.startDate.format('YYYY-MM-DD');
				fin = fechas.endDate.format('YYYY-MM-DD');
				$.get($apiUrl+'getVentasByVendedor/'+ini+'/'+fin+'/'+vend+'/'+suc, function(resp) {
					total = 0;
					if(resp.result.length > 0) {
						$.each(resp.result, function(index, item) {
							addRow(item);
							total += parseFloat(item.total);
						});
					}else{
						$('#tbl-items tbody').append('<tr><td colspan="7"><small>No existen ventas para este vendedor en el periodo</small></td></tr>');
					}
					$('#tbl-items tfoot th:eq(0) small').html(resp.result.length+' ventas registradas en el periodo');
					$('#tbl-items tfoot th:eq(2)').html('$ '+total.toFixed(2));
					doPagination(resp.result.length, lim, pag);
					$.unblockUI();
				});
			}

			function addRow(item) {
				tr = $('<tr data-ent="'+item.id+'"></tr>');
				if($('#tbl-items [data-id="'+item.id+'"]').length > 0) {
					tr = $('#tbl-items [data-id="'+item.id+'"]').parents('tr');
					tr.empty();
				}

				rspan = item.detalles.length;
				btnPrint = '';//'<a href="<?= URL_ROOT ?>/venta/print/'+item.id+'?dl=1" target="_blank" data-popup="tooltip" title="Imprimir" class="btnPrint"><i class="mdi mdi-printer"></i></a> ';
				tr.append('<td rowspan="'+rspan+' "data-id="'+item.id+'">'+btnPrint+item.folio+'</td>');
				tr.append('<td rowspan="'+rspan+'">'+item.fecha+'</td>');
				tr.append('<td rowspan="'+rspan+'"><small>'+item.cliente_nombre+'</small></td>');

				btnFact = item.fk_cfdi == 0 ? 'NO' : 'SI';
				tr.append('<td rowspan="'+rspan+'" data-mail="'+item.mail+'" class="hide">'+btnFact+'</td>');
				$.each(item.detalles, function(index, det) {
					tr.append('<td><small>'+det.prodSku+' '+det.nombre+' '+det.modelo+(det.sku!=null? ' - <strong>'+det.sku+'</strong>': '')+'</small></td>');
					tr.append('<td class="text-center">'+det.cantidad+'</td>');
					tr.append('<td class="text-right">$ '+det.costo+'</td>');
					tr.append('<td class="text-right">$ '+det.importe+'</td>');

					$('#tbl-items tbody').append(tr);
					tr = $('<tr data-ent="'+item.id+'"></tr>');
				});
			}
		
			$('#bus').keyup(function(e) { if(e.keyCode == 13) { getItems(0, $('#cont').val()); } });
			$('#btn-bus').click(function(e) { getItems(0, $('#cont').val()); });
			$('#cont').change(function() { cont = $(this).val(); getItems(0,cont); });
			//$('#busSuc').change(function() { getItems(0,$('#cont').val()); });
			$('#busVend').change(function() { createGraphSalesByCategoria(); getItems(0,$('#cont').val()); });

			$('#busSuc').change(function() { createGraphSalesByCategoria(); getItems(0,$('#cont').val()); });

			$('body').on('click', '#pag li a', function(event) {
				event.preventDefault();
				pag = parseInt($(this).attr('href'));
				cont = parseInt($('#cont').val());
				if(!$(this).parent().hasClass('active') && !$(this).parent().hasClass('active'))
					getItems(pag, cont);
			});
