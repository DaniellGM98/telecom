			function createGraphSalesByVendedor() {
				blockPage();
				fechas = $('#fechas').data('daterangepicker');
				inicial = fechas.startDate.format('YYYY-MM-DD');
				final = fechas.endDate.format('YYYY-MM-DD');
				sucursal = $('#busSuc').val();
				$.get($apiUrl+'rptVentasVendedor/'+inicial+'/'+final+'/'+sucursal, function(resp) {
					$('#salesByVendedorDateStart').html(moment(inicial).format('DD/MM/YYYY'));
					$('#salesByVendedorDateEnd').html(moment(final).format('DD/MM/YYYY'));
					labels = []; data = []; colors = []; hoverColors = [];
					$.each(resp.result, function(index, item) { labels.push(item.nombre); data.push(item.total); colors.push(getRandomRGB()); hoverColors.push(getRandomRGB()); });
					var chartSalesByVendedor = new Chart(document.getElementById("salesByVendedor").getContext('2d'), { 
						type: 'pie',
						data: {
							labels: labels,
							datasets: [{
								data: data,
								backgroundColor: colors,
								hoverBackgroundColor: colors
							}] 
						},
						options: {
							responsive: true,
							plugins: {
								legend: { 
									position: 'bottom',
								},
							}
						}
					});	
					$.unblockUI();
				}, 'json');
			}

			function createGraphSalesByCategoria() {
