	class MYPDF extends TCPDF {
		protected $info;

		public function Header() {
			if($this->info->logo) {
				$this->setJPEGQuality(90);
				list($width, $height) = getimagesize($this->info->logoUrl);
				$nh = $height * 130 / $width;
				if($nh < 41) {
					$ltMrg = ((40 - $nh) / 2) + 10;
					$this->Image($this->info->logoUrl, 10, $ltMrg, 130, 0);
				}else{
					$nw = $width * 41 / $height;
					$ltMrg = ((130 - $nw) / 2) + 10;
					$this->Image($this->info->logoUrl, $ltMrg, 10, 0, 40);
				}
			}

			$this->SetY(10);
			$this->SetFillColorArray($this->info->bgColor);
			$this->Cell(136, 5, '');
			$this->printHeader(60, 5, 'COTIZACIÓN', 1, 'C', 10);
			$this->SetTextColor(255, 0, 0);
			$this->SetFont(PDF_FONT_NAME_MAIN, 'B', 9);
			$this->Cell(136, 5, '');
			$this->Cell(60, 5, $this->info->no_doc, 1, 1, 'C');
			$this->Cell(136, 5, '');
			$this->printHeader(60, 5, 'Fecha y Hora de emisión', 1, 'C', 9);
			$this->Cell(136, 5, '');
			$this->Cell(60, 5, $this->info->fecha, 1, 1, 'C');
