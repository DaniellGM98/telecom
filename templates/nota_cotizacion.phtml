			$this->SetY(50);
			$this->Cell(0, 5, 'Lugar de Expedición: '.$this->info->lugar, 0, 1);
		}

		public function Footer() {
			if($this->info->color < 5)
				$this->SetTextColorArray($this->info->bgColor);
			else
				$this->SetTextColor(0, 0, 0);
			$paginas = "Página " . $this->PageNo() . ' de ' . $this->getAliasNbPages();
			$this->SetY(-15);
			// $publiY = $this->GetY() - 15;
		    $this->SetFont(PDF_FONT_NAME_MAIN, '', 7);
			$this->Cell(0, 3, 'Este documento tiene validez durante 30 días', 0, 1, 'C');
			$this->SetY(-11);
		    $this->Cell(0, 3, 'Este documento es informativo únicamente y no tiene validez oficial', 0, 1, 'C');
		    $this->Cell(0, 3, $paginas, 0, 0, 'C');
		}

		public function setInfo($info) {
			$this->info = $info;
		}

		public function printHeader($w, $h, $txt, $ln, $align, $font) {
			if($this->info->color < 5)
				$this->SetTextColor(255, 255, 255);
			else
				$this->SetTextColor(0, 0, 0);
			$this->SetFont(PDF_FONT_NAME_MAIN, 'B', $font);
			$this->Cell($w, $h, $txt, 1, $ln, $align, 1);
			if($this->info->color < 5)
				$this->SetTextColorArray($this->info->bgColor);
			else
				$this->SetTextColor(0, 0, 0);
			$this->SetFont(PDF_FONT_NAME_MAIN, '', ($font-1));
		}
	}


