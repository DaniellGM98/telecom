										trp.append('<td class="text-right">'+item.costo+'</td>');
										trp.append('<td class="text-right importe">'+item.importe+'</td>');
										trp.append('<td><button class="btn btn-sm btn-danger pull-right prodDel" type="button"><i class="fa fa-trash"></i></button></td>');
										
										$('#tbl-prods tbody').append(trp);
									});

									calcTotal();
									clearDataProd();

									$('#btn-cancel-cot').text('Cerrar');
									$('.only-apartado').removeClass('hide');
									$('#cot-sucursal_id, #cot-cliente_id, #cot-empleado_id').attr('disabled', 'disabled');
									$('#prod-add').parent().parent().addClass('hide');
