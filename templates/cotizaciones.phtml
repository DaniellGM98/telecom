									title: "¡Listo!",   
									text: "Se registró la cotización correctamente.",   
									timer: 4000
								});

								$.get($apartadoDetalleApiUrl+"getByApartado/"+resp.result+'/1', function(resp) {
									$('#tbl-prods tbody').empty()

									$.each(resp.result, function(index, item) {
										trp = $('<tr data-id="'+item.detalle_id+'"></tr>');
										trp.append('<td data-id="'+item.producto_id+'"><small>'+item.nombre+' '+item.modelo+' '+(item.tamano==null? '': item.tamano)+(item.sku!=null? ' - <strong>'+item.sku+'</strong>': '')+'</small></td>');
										// trp.append('<td data-id="'+item.producto_id+'"><small>['+item.sku+'] '+item.nombre+' '+item.modelo+' '+item.tamano+'</small></td>');
