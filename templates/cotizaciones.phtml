					data.detalles = [];
					preciotbl = '';
					$.each($('#tbl-prods tbody tr'), function(index, elem) { element = $(elem);
						producto_id = element.attr('data-id');
						cantidad = element.find('td:eq(1)').text();
						costo = element.find('td:eq(2)').text();
						importe = element.find('td:eq(3)').text();
						detalles = { producto_id:producto_id, origen_tipo: 1, cantidad: cantidad, costo:costo, importe:importe, };
						if($(element).next().hasClass('imei')) { detalles.arrImei = $.trim($(element).next().find('textarea').val()).split('\n').filter(imei => $.trim(imei).length>0); }

						data.detalles.push(detalles);
