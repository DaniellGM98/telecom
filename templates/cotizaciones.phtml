					alias: "numeric", groupSeparator: ',', digits: 2, digitsOptional: false, placeholder: '0'
				});

				$("#prod-cantidad, #prod-costo").change(function() {
					calcImporte();
				});
				
				function calcImporte(){
					if(!$('#prod-cantidad').prop('readonly')) { cant = parseInt($('#prod-cantidad').val()); }
					else { cant = $('#prod-imei').val().split('\n').filter(imei => $.trim(imei).length > 0).length; }
					if(isNaN(cant)) cant = 0;
					costo = parseFloat($('#prod-costo').val());
					if(isNaN(costo)) costo = 0;
					importe = cant * costo;
					$('#prod-importe').val(importe.toFixed(2));
				}

				$("#prod-cantidad, #prod-costo").keyup(function(event) { if(event.keyCode == 13) addProducto(); });
				
				$('#prod-listap').change(function() {
					pre = $(this).val();
					$('#prod-costo').val(pre).trigger('change');
				});
				
				$('#prod-add').click(function() { 
					addProducto();
				});

				function addProducto() {
					$('#frm-cot small.text-danger').html('');
					prod = $.trim($('#prod-producto').val());
					prod_id = $('#prod-id').val();
					cant = parseInt($.trim($('#prod-cantidad').val()));
					costo = $.trim($('#prod-costo').val());
					imp = $.trim($('#prod-importe').val());
					stock = parseInt($.trim($('#prod-stock').val()));
					arrImei = $.trim($('#prod-imei').val()).split('\n').filter(imei => $.trim(imei).length>0);

					if(!prodExists(prod_id) && (prod.length==0 || prod_id==0) ) {
						$('#frm-cot small.text-danger').html('Debe elegir un producto de la lista');
						$('#prod-producto').focus();
					} else if((cant.length==0 || cant==0 || isNaN(cant)) && !$('#prod-cantidad').prop('readonly')) {
						$('#frm-cot small.text-danger').html('Debe ingresar la cantidad');
						$('#prod-cantidad').focus();
					} else if(cant>stock) {
						swal({
							type: "warning",
							title: "Stock insuficiente",
							text: "Solo existen "+stock+" productos en stock",   
							timer: 4000
						});
					} else if($('#prod-imei:visible').length>0 && arrImei.length==0) {
						$('#frm-cot small.text-danger').html('Debe proporcionar todos los '+$('#prod-imei').attr('placeholder')+' de los productos');
						$('#prod-imei').focus();
					} else {
						if(prod.length>0 && ((!$('#prod-cantidad').prop('readonly') && cant>0) || ($('#prod-cantidad').prop('readonly') && arrImei.length>0)) && costo.length>0 && imp.length>0 && prod_id >0){
							if(!prodExists(prod_id)){
								if($('#prod-imei:visible').length>0) { errores = [];
									$('#prod-imei').val('');
									arrSku = []; counter = 0; agregar = true; $agregado = false;
									$.each(arrImei, function(index, item) {
										$.get('<?= URL_API ?>prod_entrada_detalle/buscarPorSku/'+item+'/'+$categoria_id+'/'+$('#prod-id').val(), function(detalle) {
											if(detalle.response) {
												$.get('<?= URL_API ?>prod_salida_detalle/buscarPorSku/'+item+'/'+$categoria_id, function(detalle) { counter++;
													if(!detalle.response) {
														if(!arrSku.includes(item)) { arrSku.push(item);
															if(counter==arrImei.length && agregar) { $agregado = true;
																$('#prod-imei').val(arrSku.join('\n')+'\n');
																
																calcImporte();
																agregarProducto_validStock(cant);
															}
														} else { agregar = false; errores.push($categoria_sku+' ('+item+'): duplicado en la venta'); }
													} else { agregar = false; errores.push($categoria_sku+' ('+item+'): agotado'); }
													$('#frm-cot small.text-danger').html(errores.join('<br>'));
													if(!$agregado) {
														$('#prod-imei').val(arrSku.join('\n')+'\n');
														calcImporte();
													}
												}, 'json');
											} else { agregar = false; errores.push($categoria_sku+' ('+item+'): no existe'); arrImei.splice(index, 1); }
											$('#frm-cot small.text-danger').html(errores.join('<br>'));
										}, 'json');
									});
								} else { agregarProducto_validStock(cant); }
							}
						}
					}
				}

				function agregarProducto_validStock(cant) {
					prod = $.trim($('#prod-producto').val());
					prod_id = $('#prod-id').val();
					cant = parseInt($.trim($('#prod-cantidad').val()));
					costo = $.trim($('#prod-costo').val());
					imp = $.trim($('#prod-importe').val());
					stock = parseInt($.trim($('#prod-stock').val()));
					arrImei = $.trim($('#prod-imei').val()).split('\n').filter(imei => $.trim(imei).length>0);

					if(cant > stock) { swal({ type:"warning", title:"Stock insuficiente", text:"Solo existen "+stock+" productos en stock", html:true, timer:4000 }); }
					else {
						trp = $('<tr data-id="'+prod_id+'"></tr>');
						trp.append('<td data-id="'+prod_id+'"><small>'+prod+'</small></td>');
						trp.append('<td class="text-right">'+($.isNumeric(cant)? cant: arrImei.length)+'</td>');
						trp.append('<td class="text-right">'+costo+'</td>');
						trp.append('<td class="text-right importe">'+imp+'</td>');
						trp.append('<td><button class="btn btn-sm btn-danger pull-right prodDel" type="button"><i class="fa fa-trash"></i></button></td>');
						$('#tbl-prods tbody').append(trp);

						if(arrImei.length>0) {
							$('#tbl-prods tbody').append('<tr class="imei" data-id="'+prod_id+'"><td colspan="5"><textarea disabled="disabled" class="form-control">'+arrImei+'</textarea></td></tr>');
							$('tr#imei').addClass('hide');
						}

						calcTotal();
						clearDataProd();
						$('#prod-producto').focus();
						$('#prod-imei').val(undefined);
					}
				}
				
				$('tbody').on('click', '.prodDel', function(event) {
					event.preventDefault();
					tr = $(this).parents('tr');
					id = tr.attr('data-id');
					content = tr.find('td:eq(0)').text();

					if(id!==undefined && id!==null && !isNaN(id)) {
						swal({   
							title: "Dar de baja producto",
							text: "Se dará de baja de la cotización el producto <strong>"+content+"</strong>, ¿Continuar?",
							type: "warning",
							html: true,
							showCancelButton: true,   
							cancelButtonText: "No",
							confirmButtonColor: "#DD6B55",   
							confirmButtonText: "Si, continuar",
							closeOnConfirm: true 
						}, function(){
							$.ajax({
								url: $apartadoDetalleApiUrl+'del/'+id,
								type: 'PUT',
								dataType: 'json',
								success: function(resp) {
									$('#tbl-prods tbody tr[data-id="'+id+'"]').remove();
									// tr.remove();
									calcTotal();

									id = $('#cot-id').val();
									data = {subtotal: $('#cot-subtotal').val(), iva: $('#cot-iva').val(), total: $('#cot-total').val()};
									$.ajax({
										url: $apartadoApiUrl+'edit/'+id,
										type: 'POST',
										dataType: 'json',
										data: data,
										success: function(resp) {
											if(resp.response){
												swal({
													type: "success",
													title: "¡Listo!",
													text: "Cotización actualizada exitosamente",   
													timer: 4000
												});

												getCotizaciones();
											}
										}
									});
								}
							});
						});
					} else {
						$('#tbl-prods tbody tr[data-id="'+id+'"]').remove();
						// tr.remove();
						calcTotal();
					}
				});

				$('#btn-save-cot').click(function() {
					btnCoti = $(this);
					$('.invalid-tooltip').remove();

					data = {};
					$.each($('[id^="cot-"]'), function(index, elem) {
						ide = $(elem).attr('id').replace('cot-','');
						data[ide] = $.trim($(elem).val());
					});
