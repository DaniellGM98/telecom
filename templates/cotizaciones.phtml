				function prodExists(prod){
					if($('#tbl-prods [data-id="'+prod+'"]').length > 0){
						$errLabel = $('<div class="invalid-tooltip">Ya existe el producto</div>');
						$('#frm-cot small.text-danger').html('Ya existe el producto');
						$('#prod-producto').after($errLabel).select().focus();
						$errLabel.show();
						
						return true;
					}
					return false;
				}
				
