									getCotizaciones();
									//window.open('<?= URL_ROOT ?>/cotizacion/print/'+apartado_id+'?dl=1');
								}, 'json');
							} else {
								swal({
									type: "warning",
									title: "Oops!",
									text: resp.message,
									timer: 4000
								});
							}
							$.unblockUI();
						},'json');
					}
				});

				function calcTotal(){
					tot = 0;
					$.each($('#tbl-prods tbody .importe'), function(index, elem) {
						imp = parseFloat($(elem).text());
						tot += imp;
					});
					sub = tot;
					iva = sub * parseInt('<?= $_SESSION['iva'] ?>') / 100;
					tot += iva;
					$('#cot-subtotal').val(sub.toFixed(2));
					$('#cot-iva').val(iva.toFixed(2));
					$('#cot-total').val(tot.toFixed(2));
				}

				function clearDataProd(){
					$('.invalid-tooltip').remove();
					$('#tbl-prods input').val('');
					$('#prod-producto').typeahead('val','');
					$('#prod-id').val(0);
					$('#prod-listap').empty();
				}
				
				function clearData(){
					$('.invalid-tooltip').remove();
					$('#frm-cot input').val('');
